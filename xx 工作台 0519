  var tasksOnly=['view-seg','toolbar-sep3','toolbar-sep2','toolbar-filters','toolbar-sep1','toolbar-inbox-btn','toolbar-add-btn'];
  var showTaskbar=tab==='tasks';
  var showTodaybar=tab==='today';
