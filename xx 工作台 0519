<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>工作台 v2.8C</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css">
<style>
:root{
  --bg:#eef0f5;--surface:#ffffff;--surface2:#f4f5f8;--surface3:#e8e9ee;--surface4:#c7c7cc;
  --border:rgba(60,60,67,.09);--border2:rgba(60,60,67,.15);
  --text1:#1c1c1e;--text2:#48484a;--text3:#8e8e93;--text4:#aeaeb2;
  --accent:#007aff;--accent-light:rgba(0,122,255,.1);--accent-border:rgba(0,122,255,.3);
  --done:#34c759;--done-light:rgba(52,199,89,.12);
  --del:#ff3b30;--warn:#ff9500;
  --s-todo:#8e8e93;--s-doing:#007aff;--s-done:#34c759;--s-cancel:#ff9500;
  --shadow-xs:0 1px 2px rgba(0,0,0,.05);
  --shadow-sm:0 2px 10px rgba(0,0,0,.08),0 1px 3px rgba(0,0,0,.05);
  --shadow:0 6px 24px rgba(0,0,0,.1),0 2px 8px rgba(0,0,0,.06);
  --shadow-lg:0 16px 48px rgba(0,0,0,.14),0 6px 16px rgba(0,0,0,.08);
  --shadow-card:0 2px 12px rgba(0,0,0,.07),0 1px 4px rgba(0,0,0,.05),inset 0 1px 0 rgba(255,255,255,.8);
  --r:13px;--rs:11px;--rxs:8px;
  --ease:cubic-bezier(.25,.46,.45,.94);--spring:cubic-bezier(.34,1.56,.64,1);
  --sidebar-w:176px;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
body{font-family:'Noto Sans SC',-apple-system,BlinkMacSystemFont,system-ui,sans-serif;background:var(--bg);color:var(--text1);height:100dvh;display:flex;flex-direction:row;overflow:hidden;font-size:14px;-webkit-font-smoothing:antialiased;letter-spacing:-.01em}
body::before{content:'';position:fixed;inset:0;background:radial-gradient(ellipse at 20% 0%,rgba(0,122,255,.04) 0%,transparent 60%),radial-gradient(ellipse at 80% 100%,rgba(52,199,89,.03) 0%,transparent 60%);pointer-events:none;z-index:0}
@keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
@keyframes cardIn{from{opacity:0;transform:translateY(14px) scale(.97)}to{opacity:1;transform:translateY(0) scale(1)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes slideUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@keyframes slideInRight{from{opacity:0;transform:translateX(24px)}to{opacity:1;transform:translateX(0)}}
@keyframes strikeThrough{from{width:0}to{width:100%}}
@keyframes checkPop{0%{transform:scale(1)}35%{transform:scale(1.22)}70%{transform:scale(.9)}100%{transform:scale(1)}}
@keyframes checkRing{0%{box-shadow:0 0 0 0 rgba(52,199,89,.4)}100%{box-shadow:0 0 0 12px rgba(52,199,89,0)}}
@keyframes pulse{0%,100%{opacity:.4}50%{opacity:1}}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--surface4);border-radius:4px}

/* ── SIDEBAR ── */
.sidebar{width:var(--sidebar-w);flex-shrink:0;height:100dvh;background:rgba(255,255,255,.78);backdrop-filter:blur(32px) saturate(200%);-webkit-backdrop-filter:blur(32px) saturate(200%);border-right:1px solid rgba(60,60,67,.1);display:flex;flex-direction:column;z-index:50;box-shadow:2px 0 20px rgba(0,0,0,.05);position:relative}
.sb-header{padding:16px 14px 12px;border-bottom:1px solid var(--border);flex-shrink:0}
.sb-logo{font-size:15px;font-weight:600;color:var(--text1);display:flex;align-items:baseline;gap:6px;letter-spacing:-.02em}
.sb-logo-ver{font-size:10px;color:var(--text4);font-weight:400;background:rgba(118,118,128,.1);padding:1px 6px;border-radius:4px}
.sb-date{font-size:11px;color:var(--text3);margin-top:5px;line-height:1.4}
.sb-nav{flex:1;overflow-y:auto;padding:8px 8px 4px}
.sb-section{font-size:10px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text4);padding:8px 8px 4px;margin-top:4px}
.sb-section:first-child{margin-top:0}
.sb-btn{width:100%;display:flex;align-items:center;gap:9px;padding:7px 10px;border-radius:var(--rxs);border:none;background:transparent;color:var(--text2);cursor:pointer;font-family:inherit;font-size:13px;text-align:left;transition:background .15s,color .15s;position:relative;white-space:nowrap}
.sb-btn:hover{background:rgba(0,122,255,.06);color:var(--text1)}
.sb-btn.active{background:rgba(0,122,255,.1);color:var(--accent)}
.sb-btn.active .sb-icon{color:var(--accent)}
.sb-icon{font-size:16px;width:20px;text-align:center;flex-shrink:0;line-height:1;color:var(--text3);transition:color .15s}
.sb-label{flex:1;font-weight:400}
.sb-btn.active .sb-label{font-weight:500}
.sb-badge{background:var(--del);color:#fff;font-size:9.5px;font-weight:700;min-width:17px;height:17px;border-radius:9px;display:flex;align-items:center;justify-content:center;padding:0 4px;flex-shrink:0}
.sb-count{font-size:11px;color:var(--text4);flex-shrink:0}
.sb-btn.active .sb-count{color:var(--accent)}
.sb-divider{height:1px;background:var(--border);margin:6px 8px}
.sb-bottom{padding:8px 8px 12px;border-top:1px solid var(--border);flex-shrink:0}

/* ── APP BODY ── */
.app-body{flex:1;display:flex;flex-direction:column;height:100dvh;overflow:hidden;min-width:0;position:relative;z-index:1}
.topbar{background:rgba(242,242,247,.92);backdrop-filter:blur(24px) saturate(180%);-webkit-backdrop-filter:blur(24px) saturate(180%);border-bottom:1px solid var(--border);padding:0 20px;height:46px;display:flex;align-items:center;gap:12px;flex-shrink:0;z-index:40}
.topbar-title{font-size:16px;font-weight:600;color:var(--text1);letter-spacing:-.02em;flex-shrink:0}
.topbar-spacer{flex:1}
.search-trigger{height:32px;background:rgba(118,118,128,.1);border:1px solid transparent;border-radius:10px;display:flex;align-items:center;gap:7px;padding:0 12px;cursor:pointer;transition:background .15s;min-width:200px;max-width:280px}
.search-trigger:hover{background:rgba(118,118,128,.16)}
.search-trigger-text{font-size:12.5px;color:var(--text3);flex:1}
.search-kbd{font-size:10px;color:var(--text4);background:rgba(118,118,128,.12);border:1px solid var(--border2);border-radius:4px;padding:1px 5px;font-family:monospace}
.topbar-date{font-size:12px;color:var(--text3);flex-shrink:0;white-space:nowrap}

/* ── TOOLBAR ── */
.toolbar{background:rgba(248,248,252,.9);border-bottom:1px solid var(--border);padding:0 20px;height:40px;display:flex;align-items:center;gap:8px;flex-shrink:0}
.toolbar-spacer{flex:1}
.filter-pill{height:24px;padding:0 11px;border-radius:12px;border:1px solid var(--border2);background:transparent;font-size:12px;color:var(--text2);cursor:pointer;font-family:inherit;transition:background .12s,color .12s;white-space:nowrap}
.filter-pill:hover{background:rgba(118,118,128,.08)}
.filter-pill.active{background:var(--accent-light);border-color:var(--accent-border);color:var(--accent);font-weight:500}
.toolbar-btn{height:24px;padding:0 11px;border-radius:12px;border:1px solid var(--border2);background:transparent;font-size:12px;color:var(--text2);cursor:pointer;font-family:inherit;display:flex;align-items:center;gap:5px;white-space:nowrap;transition:background .12s}
.toolbar-btn:hover{background:rgba(118,118,128,.08)}
.toolbar-btn i{font-size:13px}
.btn-add{height:28px;padding:0 14px;background:var(--accent);color:#fff;border:none;border-radius:14px;font-size:12.5px;font-weight:500;font-family:inherit;cursor:pointer;display:flex;align-items:center;gap:5px;transition:opacity .12s,transform .1s;white-space:nowrap;flex-shrink:0}
.btn-add:hover{opacity:.88}
.btn-add:active{transform:scale(.97)}
.inbox-btn{height:24px;padding:0 10px;border-radius:12px;border:1px solid var(--border2);background:transparent;font-size:12px;color:var(--text2);cursor:pointer;font-family:inherit;display:flex;align-items:center;gap:5px;white-space:nowrap;transition:background .12s}
.inbox-btn:hover{background:rgba(118,118,128,.08)}
.inbox-badge{background:var(--del);color:#fff;font-size:9px;font-weight:700;min-width:15px;height:15px;border-radius:8px;display:flex;align-items:center;justify-content:center;padding:0 3px}

/* view toggle seg */
.view-seg{display:flex;background:var(--surface3);border-radius:var(--rxs);padding:2px;gap:1px}
.view-seg-btn{height:22px;padding:0 10px;border:none;border-radius:6px;background:none;font-size:12px;cursor:pointer;color:var(--text3);font-family:inherit;display:flex;align-items:center;gap:4px;transition:all .15s;white-space:nowrap}
.view-seg-btn i{font-size:13px}
.view-seg-btn.active{background:var(--surface);color:var(--text1);font-weight:500;box-shadow:0 1px 3px rgba(0,0,0,.1)}

/* ── MAIN / PAGES ── */
.main{flex:1;overflow:hidden;position:relative}
.page{position:absolute;inset:0;overflow-y:auto;opacity:0;pointer-events:none;transition:opacity .15s var(--ease)}
.page.active{opacity:1;pointer-events:all;animation:cardIn .22s var(--spring)}
.wrap{padding:20px 24px 60px;max-width:960px;margin:0 auto}
.wrap-full{padding:16px 20px 40px}
.section-label{font-size:11px;font-weight:600;letter-spacing:.04em;text-transform:uppercase;color:var(--text3);margin-bottom:8px;padding:0 2px;display:flex;align-items:center;gap:8px}
.section-label::after{content:'';flex:1;height:1px;background:var(--border)}
.empty-state{text-align:center;padding:60px 20px;color:var(--text3);font-size:13px}
.empty-icon{font-size:40px;margin-bottom:12px}
.empty-state p{line-height:1.7}

/* ── TODAY CAPTURE ── */
.capture-box{background:var(--surface);border-radius:var(--r);box-shadow:var(--shadow-sm);padding:4px;margin-bottom:20px;transition:box-shadow .2s;border:1px solid var(--border)}
.capture-box:focus-within{box-shadow:var(--shadow),0 0 0 3px var(--accent-light);border-color:var(--accent-border)}
.capture-input{width:100%;border:none;outline:none;background:transparent;font-family:inherit;font-size:15px;color:var(--text1);padding:10px 14px 8px;resize:none;line-height:1.5;min-height:44px;max-height:120px;display:block}
.capture-input::placeholder{color:var(--text4)}
.capture-footer{display:flex;align-items:center;justify-content:space-between;padding:4px 10px 6px;gap:8px}
.capture-tags{display:flex;gap:5px;flex-wrap:wrap;flex:1}
.capture-tag-btn{height:22px;padding:0 10px;border-radius:11px;border:1px solid var(--border2);background:rgba(118,118,128,.08);font-size:11px;color:var(--text2);cursor:pointer;font-family:inherit;transition:background .12s,color .12s}
.capture-tag-btn:hover,.capture-tag-btn.selected{background:var(--accent-light);border-color:var(--accent-border);color:var(--accent);font-weight:500}
.capture-submit{height:28px;padding:0 16px;background:var(--accent);color:#fff;border:none;border-radius:14px;font-size:13px;font-weight:500;font-family:inherit;cursor:pointer;flex-shrink:0;transition:opacity .12s}
.capture-submit:hover{opacity:.88}
.date-chip{display:inline-flex;align-items:center;gap:4px;background:var(--accent-light);border:1px solid var(--accent-border);color:var(--accent);font-size:11px;padding:2px 8px;border-radius:10px;margin:0 2px 4px;font-weight:500}

/* ── TASK ITEMS ── */
.tasks-group{margin-bottom:8px}
.tasks-group-label{font-size:11px;font-weight:600;color:var(--text3);margin-bottom:5px;padding:0 2px;display:flex;align-items:center;gap:6px;cursor:pointer;user-select:none;letter-spacing:.03em}
.tasks-group-label::after{content:'';flex:1;height:1px;background:var(--border)}
.tasks-group-label-pin{color:var(--warn)}
.tasks-group-label-pin::after{background:rgba(255,149,0,.2)}
.task-item{background:var(--surface);border:1px solid var(--border);border-radius:var(--rs);padding:10px 14px;display:flex;align-items:flex-start;gap:11px;transition:box-shadow .2s,transform .18s var(--ease);animation:cardIn .2s var(--spring) both;margin-bottom:5px;box-shadow:var(--shadow-card);will-change:transform}
.task-item:hover{background:#fafcff;box-shadow:0 6px 22px rgba(0,0,0,.09),0 2px 6px rgba(0,0,0,.05),inset 0 1px 0 rgba(255,255,255,.9);transform:translateY(-1px)}
.task-item.done{opacity:.5}
.task-item.pinned{background:#fffbf0;border-color:rgba(255,149,0,.2)}
.task-check{width:20px;height:20px;border-radius:50%;border:1.5px solid var(--surface4);flex-shrink:0;margin-top:1px;display:flex;align-items:center;justify-content:center;transition:all .18s;background:transparent;cursor:pointer}
.task-item.done .task-check{background:var(--done);border-color:var(--done);animation:checkPop .28s var(--spring),checkRing .5s ease-out .1s}
.task-check svg{display:none}
.task-item.done .task-check svg{display:block}
.task-body{flex:1;min-width:0;cursor:pointer}
.task-title{font-size:14px;color:var(--text1);line-height:1.4;word-break:break-all;position:relative;display:inline-block}
.task-item.done .task-title{color:var(--text4)}
.task-item.done .task-title::after{content:'';position:absolute;left:0;top:50%;height:1px;background:var(--text4);animation:strikeThrough .2s var(--ease) forwards}
.task-note-preview{font-size:12px;color:var(--text3);margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.task-meta{display:flex;align-items:center;gap:5px;margin-top:4px;flex-wrap:wrap}
.task-tag{font-size:11px;color:var(--accent);font-weight:500;background:var(--accent-light);padding:1px 6px;border-radius:4px}
.task-date{font-size:11px;color:var(--text3)}
.task-date.overdue{color:var(--del);font-weight:500}
.status-badge{font-size:10.5px;padding:1px 7px;border-radius:4px;font-weight:500;white-space:nowrap}
.sb-todo{background:rgba(142,142,147,.12);color:var(--s-todo)}
.sb-doing{background:var(--accent-light);color:var(--s-doing)}
.sb-done{background:rgba(52,199,89,.12);color:var(--s-done)}
.sb-cancel{background:rgba(255,149,0,.12);color:var(--s-cancel)}
.pri-badge{font-size:11px;color:var(--text3)}
.task-actions{display:flex;gap:2px;opacity:0;transition:opacity .15s;flex-shrink:0;margin-top:1px}
.task-item:hover .task-actions{opacity:1}
.task-act-btn{width:24px;height:24px;border-radius:var(--rxs);border:none;background:transparent;color:var(--text3);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:13px;transition:background .12s,color .12s}
.task-act-btn:hover{background:rgba(118,118,128,.12)}
.task-act-btn.del:hover{color:var(--del)}
.task-act-btn.pin-btn.active{color:var(--warn)}
.task-links{display:flex;flex-wrap:wrap;gap:4px;margin:4px 0 2px}
.task-link-chip{display:inline-flex;align-items:center;gap:4px;font-size:11px;color:var(--accent);background:var(--accent-light);border-radius:5px;padding:2px 7px;text-decoration:none;font-weight:500;transition:opacity .12s;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.task-link-chip:hover{opacity:.78}
.task-img-row{display:flex;gap:3px;align-items:center;flex-shrink:0;cursor:pointer}
.task-img-icon{width:28px;height:28px;object-fit:cover;border-radius:5px;border:1px solid var(--border);transition:opacity .12s}
.task-img-icon:hover{opacity:.8}

/* ── KANBAN ── */
.kanban-wrap{flex:1;overflow:hidden;display:grid;grid-template-columns:repeat(4,1fr);gap:10px;padding:16px 20px}
.k-col{background:var(--surface);border-radius:var(--r);border:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden;box-shadow:var(--shadow-xs);animation:cardIn .22s var(--spring)}
.k-col-bar{height:3px;flex-shrink:0}
.k-head{padding:10px 12px 8px;display:flex;align-items:center;gap:7px;border-bottom:1px solid var(--border);flex-shrink:0}
.k-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.k-label{font-size:12.5px;font-weight:500;color:var(--text1);flex:1}
.k-count{font-size:11px;color:var(--text3);background:var(--surface2);border-radius:8px;min-width:20px;height:18px;display:flex;align-items:center;justify-content:center;padding:0 5px}
.k-body{flex:1;overflow-y:auto;padding:8px;display:flex;flex-direction:column;gap:5px}
.k-card{background:var(--surface2);border:1px solid var(--border);border-radius:var(--rxs);padding:9px 10px;cursor:grab;transition:background .12s,border-color .12s,transform .15s var(--ease),opacity .15s;animation:cardIn .2s var(--spring) both}
.k-card:active{cursor:grabbing}
.k-card:hover{background:#fafcff;border-color:var(--border2);transform:translateY(-1px)}
.k-card.done{opacity:.5}
.k-card.dragging{opacity:.3;transform:scale(.96)}
.k-body.drag-over{background:var(--accent-light);outline:2px dashed var(--accent-border);outline-offset:-2px;border-radius:var(--rxs)}
.k-card-title{font-size:12.5px;color:var(--text1);line-height:1.4;margin-bottom:5px}
.k-card.done .k-card-title{text-decoration:line-through;color:var(--text4)}
.k-card-meta{display:flex;align-items:center;gap:4px;flex-wrap:wrap}
.k-card-tag{font-size:10px;color:var(--accent);background:var(--accent-light);border-radius:4px;padding:1px 5px}
.k-card-pri{font-size:10.5px;color:var(--text3)}
.k-card-date{font-size:10.5px;color:var(--text4)}
.k-card-date.overdue{color:var(--del)}
.k-card-del{position:absolute;top:6px;right:6px;width:20px;height:20px;border-radius:50%;border:none;background:rgba(255,59,48,.12);color:var(--del);font-size:12px;cursor:pointer;display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .15s}
.k-card{position:relative}
.k-card:hover .k-card-del{opacity:1}
.mx-item-del{position:absolute;top:6px;right:6px;width:20px;height:20px;border-radius:50%;border:none;background:rgba(255,59,48,.12);color:var(--del);font-size:12px;cursor:pointer;display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .15s}
.mx-item{position:relative}
.mx-item:hover .mx-item-del{opacity:1}

/* ── MATRIX ── */
.matrix-wrap{flex:1;overflow:hidden;display:flex;flex-direction:column;padding:12px 20px 16px}
.mx-axis-row{display:flex;align-items:center;justify-content:space-between;font-size:11px;color:var(--text3);padding:0 2px;margin-bottom:8px;flex-shrink:0}
.mx-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;flex:1;overflow:hidden}
.mx-cell{border-radius:var(--r);border-width:1.5px;border-style:solid;padding:12px;display:flex;flex-direction:column;overflow:hidden}
.mx-cell.q1{border-color:#ff3b30;background:rgba(255,59,48,.04)}
.mx-cell.q2{border-color:#007aff;background:rgba(0,122,255,.04)}
.mx-cell.q3{border-color:#ff9500;background:rgba(255,149,0,.04)}
.mx-cell.q4{border-color:var(--border2);background:var(--surface2)}
.mx-hdr{font-size:11.5px;font-weight:600;margin-bottom:8px;flex-shrink:0;display:flex;align-items:center;gap:5px}
.mx-cell.q1 .mx-hdr{color:#d62f26}.mx-cell.q2 .mx-hdr{color:var(--accent)}.mx-cell.q3 .mx-hdr{color:#d97800}.mx-cell.q4 .mx-hdr{color:var(--text3)}
.mx-items{flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:4px}
.mx-item{font-size:13px;color:var(--text1);padding:8px 10px;background:var(--surface);border-radius:var(--rxs);cursor:grab;border:1px solid var(--border);transition:border-color .12s,transform .15s,opacity .15s;animation:fadeUp .15s var(--ease) both}
.mx-item:active{cursor:grabbing}
.mx-item:hover{border-color:var(--border2);transform:translateY(-1px)}
.mx-item.done{opacity:.5}
.mx-item.dragging{opacity:.3;transform:scale(.96)}
.mx-item.done .mx-item-title{text-decoration:line-through;color:var(--text4)}
.mx-cell.drag-over{outline:2px dashed var(--accent-border);outline-offset:-2px;background-color:rgba(0,122,255,.07)}
.mx-item-title{font-size:12.5px;line-height:1.4;margin-bottom:3px}
.mx-item-meta{display:flex;gap:4px;align-items:center}
.mx-item-tag{font-size:10px;color:var(--accent);background:var(--accent-light);padding:1px 5px;border-radius:4px}
.mx-item-st{font-size:10px;color:var(--text3)}

/* ── NOTES ── */
.notes-toolbar{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:14px}
.notes-filter-btn{height:26px;padding:0 12px;border-radius:13px;border:1px solid var(--border2);background:transparent;font-size:12px;color:var(--text2);cursor:pointer;font-family:inherit;white-space:nowrap;transition:background .12s,color .12s}
.notes-filter-btn.active{background:var(--accent-light);border-color:var(--accent-border);color:var(--accent);font-weight:500}
.notes-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:10px}
.note-card{background:var(--surface);border-radius:var(--r);padding:14px 16px;cursor:pointer;transition:box-shadow .2s,transform .18s var(--ease);box-shadow:var(--shadow-card);border:1px solid var(--border);animation:cardIn .2s var(--spring) both}
.note-card:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.1)}
.note-card.cat-experience{border-left:3px solid #5856d6}
.note-card.cat-method{border-left:3px solid #32ade6}
.note-card.cat-idea{border-left:3px solid var(--warn)}
.note-card.cat-review{border-left:3px solid var(--accent)}
.note-card.cat-followup{border-left:3px solid var(--done)}
.note-card.cat-other{border-left:3px solid var(--surface4)}
.note-card-title{font-size:14px;font-weight:500;color:var(--text1);margin-bottom:4px;line-height:1.35}
.note-card-body{font-size:12.5px;color:var(--text2);line-height:1.6;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
.note-card-foot{display:flex;align-items:center;justify-content:space-between;margin-top:8px}
.note-card-cat{font-size:11px;font-weight:600;color:var(--text3)}
.note-card.cat-experience .note-card-cat{color:#5856d6}
.note-card.cat-method .note-card-cat{color:#32ade6}
.note-card.cat-idea .note-card-cat{color:var(--warn)}
.note-card.cat-review .note-card-cat{color:var(--accent)}
.note-card.cat-followup .note-card-cat{color:var(--done)}
.note-card-date{font-size:11px;color:var(--text4)}
.note-del-btn{background:none;border:none;cursor:pointer;color:var(--text4);font-size:12px;padding:2px 6px;border-radius:4px;opacity:0;font-family:inherit;transition:color .12s}
.note-card:hover .note-del-btn{opacity:1}
.note-del-btn:hover{color:var(--del)}

/* ── BOOKS ── */
.book-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px}
.book-card{background:var(--surface);border-radius:var(--r);overflow:hidden;cursor:pointer;border:1px solid var(--border);box-shadow:var(--shadow-card);transition:box-shadow .2s,transform .18s var(--ease);animation:cardIn .2s var(--spring) both}
.book-card:hover{transform:translateY(-3px);box-shadow:0 10px 28px rgba(0,0,0,.1)}
.book-card-head{padding:14px 16px;display:flex;align-items:center;gap:12px}
.book-spine{width:34px;height:46px;border-radius:5px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:16px}
.book-info{flex:1;min-width:0}
.book-title{font-size:14px;font-weight:500;color:var(--text1);margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.book-author{font-size:12px;color:var(--text3)}
.book-count{font-size:12px;color:var(--text3)}
.book-notes-preview{border-top:1px solid var(--border);padding:8px 16px;background:rgba(118,118,128,.03)}
.book-note-preview-item{font-size:12px;color:var(--text2);line-height:1.5;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;padding:1px 0}
.book-note-preview-item::before{content:'❝ ';color:var(--text4);font-size:10px}

/* ── REVIEW ── */
.review-card{background:var(--surface);border-radius:var(--r);padding:14px 16px;cursor:pointer;border:1px solid var(--border);box-shadow:var(--shadow-card);margin-bottom:8px;animation:cardIn .2s var(--spring) both;transition:box-shadow .2s,transform .18s var(--ease)}
.review-card:hover{transform:translateY(-1px);box-shadow:0 6px 20px rgba(0,0,0,.09)}
.review-card-title{font-size:14px;font-weight:500;color:var(--text1);margin-bottom:4px}
.review-card-preview{font-size:12.5px;color:var(--text2);line-height:1.6;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.review-card-foot{display:flex;align-items:center;justify-content:space-between;margin-top:8px}
.review-q-block{margin-bottom:16px}
.review-q-label{font-size:11.5px;font-weight:600;color:var(--text3);margin-bottom:6px;display:flex;align-items:center;gap:5px;letter-spacing:.01em;text-transform:uppercase}
.review-q-input{width:100%;border:none;outline:none;background:rgba(118,118,128,.07);border-radius:var(--rs);font-family:inherit;font-size:14px;color:var(--text1);padding:11px 13px;resize:none;line-height:1.65;min-height:76px;transition:background .15s,box-shadow .15s}
.review-q-input:focus{background:var(--surface);box-shadow:0 0 0 2px var(--accent-border)}

/* ── DATA ANALYSIS ── */
.an-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px}
.an-kpi{background:var(--surface);border-radius:var(--r);border:1px solid var(--border);padding:16px;box-shadow:var(--shadow-card);animation:cardIn .2s var(--spring)}
.an-kpi-label{font-size:11px;color:var(--text3);font-weight:600;letter-spacing:.04em;text-transform:uppercase;margin-bottom:6px}
.an-kpi-val{font-size:26px;font-weight:700;color:var(--text1);line-height:1;margin-bottom:4px}
.an-kpi-sub{font-size:11.5px;color:var(--text3)}
.an-charts{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.an-card{background:var(--surface);border-radius:var(--r);border:1px solid var(--border);padding:16px;box-shadow:var(--shadow-card);animation:cardIn .22s var(--spring)}
.an-card-title{font-size:12.5px;font-weight:600;color:var(--text2);letter-spacing:.02em;margin-bottom:12px}
.an-bar-row{display:flex;align-items:center;gap:8px;margin-bottom:7px}
.an-bar-label{font-size:12px;color:var(--text2);width:72px;text-align:right;flex-shrink:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.an-bar-track{flex:1;height:10px;background:var(--surface2);border-radius:5px;overflow:hidden}
.an-bar-fill{height:100%;border-radius:5px;transition:width .5s var(--ease)}
.an-bar-count{font-size:11px;color:var(--text3);width:24px;text-align:right;flex-shrink:0}
.an-week-bars{display:flex;align-items:flex-end;gap:6px;height:100px;padding-top:8px}
.an-week-col{flex:1;display:flex;flex-direction:column;align-items:center;gap:4px}
.an-week-bar{width:100%;border-radius:4px 4px 0 0;background:var(--accent-light);transition:height .5s var(--ease),background .2s;min-height:2px}
.an-week-bar.today{background:var(--accent)}
.an-week-label{font-size:10px;color:var(--text3);white-space:nowrap}
.an-week-val{font-size:10px;color:var(--text4)}

/* ── INBOX (Drawer) ── */
.inbox-drawer{position:fixed;top:0;right:0;bottom:0;width:340px;background:rgba(248,248,252,.98);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border-left:1px solid var(--border);box-shadow:-4px 0 24px rgba(0,0,0,.12);z-index:200;display:flex;flex-direction:column;transform:translateX(100%);transition:transform .25s var(--ease)}
.inbox-drawer.open{transform:translateX(0)}
.inbox-drawer-header{padding:16px 18px 12px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;flex-shrink:0}
.inbox-drawer-title{font-size:15px;font-weight:600;color:var(--text1);flex:1}
.inbox-drawer-body{flex:1;overflow-y:auto;padding:12px 14px}
.inbox-capture{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:4px;margin-bottom:12px}
.inbox-capture:focus-within{border-color:var(--accent-border);box-shadow:0 0 0 3px var(--accent-light)}
.inbox-capture-input{width:100%;border:none;outline:none;background:transparent;font-family:inherit;font-size:14px;color:var(--text1);padding:9px 12px 7px;resize:none;line-height:1.5;min-height:40px;max-height:120px}
.inbox-capture-input::placeholder{color:var(--text4)}
.inbox-capture-footer{padding:4px 10px 6px;display:flex;justify-content:flex-end}
.inbox-item{background:var(--surface);border:1px solid var(--border);border-radius:var(--rs);padding:10px 12px;margin-bottom:5px;cursor:pointer;animation:fadeUp .15s var(--ease) both;transition:border-color .12s}
.inbox-item:hover{border-color:var(--border2)}
.inbox-item-title{font-size:13.5px;color:var(--text1);line-height:1.4;margin-bottom:4px}
.inbox-item-meta{display:flex;gap:6px;align-items:center}
.inbox-item-date{font-size:11px;color:var(--text4)}
.inbox-item-actions{display:flex;gap:4px;opacity:0;transition:opacity .12s}
.inbox-item:hover .inbox-item-actions{opacity:1}
.inbox-act-btn{height:22px;padding:0 8px;border-radius:11px;border:1px solid var(--border2);background:transparent;font-size:11px;cursor:pointer;font-family:inherit;color:var(--text2);transition:background .12s}
.inbox-act-btn:hover{background:rgba(118,118,128,.1)}
.inbox-act-btn.promote{color:var(--accent);border-color:var(--accent-border);background:var(--accent-light)}

/* ── SUB PANEL ── */
.sub-panel{position:absolute;inset:0;background:var(--bg);z-index:10;overflow-y:auto;animation:slideInRight .2s var(--ease)}
.sub-panel-header{background:rgba(242,242,247,.92);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(--border);padding:12px 20px;display:flex;align-items:center;gap:10px;position:sticky;top:0;z-index:5}
.back-btn{display:flex;align-items:center;gap:4px;background:none;border:none;cursor:pointer;color:var(--accent);font-size:14px;font-family:inherit;padding:2px 6px;border-radius:6px;transition:opacity .12s;flex-shrink:0}
.back-btn:hover{opacity:.7}
.sub-panel-body{padding:24px 28px 80px;max-width:720px;margin:0 auto}
.note-detail-title-input{width:100%;border:none;outline:none;background:transparent;font-family:inherit;font-size:22px;font-weight:600;color:var(--text1);padding:0 0 14px;border-bottom:1px solid var(--border);margin-bottom:16px;letter-spacing:-.02em}
.note-detail-body-input{width:100%;border:none;outline:none;background:transparent;font-family:inherit;font-size:14.5px;color:var(--text1);line-height:1.75;resize:none;min-height:40vh}
.note-cat-select{height:26px;padding:0 10px;border-radius:13px;border:1px solid var(--border2);background:rgba(118,118,128,.08);font-family:inherit;font-size:12px;color:var(--text2);outline:none;cursor:pointer}
.note-images-wrap{display:flex;flex-wrap:wrap;gap:8px;padding:12px 0 4px}
.note-img-item{position:relative;display:inline-block}
.note-img{width:100px;height:76px;object-fit:cover;border-radius:var(--rxs);border:1px solid var(--border);cursor:zoom-in;transition:opacity .12s}
.note-img:hover{opacity:.8}
.note-img-del{position:absolute;top:-6px;right:-6px;width:18px;height:18px;border-radius:50%;background:var(--del);color:#fff;border:none;cursor:pointer;font-size:11px;display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .15s}
.note-img-item:hover .note-img-del{opacity:1}
.note-add-box{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:4px;margin-bottom:16px;transition:box-shadow .2s,border-color .2s}
.note-add-box:focus-within{border-color:var(--accent-border);box-shadow:0 0 0 3px var(--accent-light)}
.note-textarea{width:100%;border:none;outline:none;background:transparent;font-family:inherit;font-size:14px;color:var(--text1);padding:10px 12px;resize:none;line-height:1.65;min-height:76px}
.note-textarea::placeholder{color:var(--text4);font-style:italic}
.note-type-select{height:24px;padding:0 8px;border-radius:12px;border:1px solid var(--border2);background:rgba(118,118,128,.08);font-family:inherit;font-size:11.5px;color:var(--text2);outline:none;cursor:pointer}
.book-note-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--rs);padding:12px 14px;margin-bottom:7px;animation:fadeUp .16s var(--ease) both}
.book-note-card.type-quote{border-left:3px solid var(--accent)}
.book-note-card.type-thought{border-left:3px solid var(--warn)}
.book-note-type{font-size:10px;font-weight:600;letter-spacing:.05em;text-transform:uppercase;color:var(--text3);margin-bottom:5px}
.book-note-card.type-quote .book-note-type{color:var(--accent)}
.book-note-card.type-thought .book-note-type{color:var(--warn)}
.book-note-text{font-size:14px;line-height:1.6;color:var(--text1)}
.book-note-card.type-quote .book-note-text{font-style:italic;color:var(--text2)}
.book-note-footer{display:flex;align-items:center;justify-content:space-between;margin-top:7px}
.book-note-date{font-size:11px;color:var(--text4)}

/* ── MODAL ── */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.4);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);z-index:400;display:flex;align-items:center;justify-content:center;animation:fadeIn .16s ease}
.modal{background:rgba(242,242,247,.98);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-radius:16px;width:100%;max-width:480px;max-height:86dvh;overflow-y:auto;animation:slideUp .22s var(--spring);box-shadow:var(--shadow-lg)}
.modal-header{padding:14px 20px 12px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;background:rgba(242,242,247,.95);backdrop-filter:blur(16px);z-index:1}
.modal-title{font-size:16px;font-weight:600;color:var(--text1)}
.modal-close{width:26px;height:26px;border-radius:50%;border:none;background:rgba(118,118,128,.16);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:14px;color:var(--text2)}
.modal-body{padding:14px 20px 8px}
.modal-field{margin-bottom:13px}
.modal-label{font-size:12px;font-weight:500;color:var(--text2);margin-bottom:6px;display:block}
.modal-input{width:100%;height:40px;padding:0 13px;border:1px solid var(--border2);border-radius:var(--rs);background:var(--surface);font-family:inherit;font-size:14px;color:var(--text1);outline:none;transition:border-color .12s,box-shadow .12s}
.modal-input:focus{border-color:var(--accent-border);box-shadow:0 0 0 3px var(--accent-light)}
.modal-input::placeholder{color:var(--text4)}
.modal-select{width:100%;height:40px;padding:0 13px;border:1px solid var(--border2);border-radius:var(--rs);background:var(--surface);font-family:inherit;font-size:14px;color:var(--text1);outline:none;cursor:pointer}
.modal-tag-row{display:flex;gap:7px;flex-wrap:wrap}
.modal-tag-opt{height:28px;padding:0 14px;border-radius:14px;border:1px solid var(--border2);background:transparent;font-size:12.5px;color:var(--text2);cursor:pointer;font-family:inherit;transition:background .12s}
.modal-tag-opt.selected{background:var(--accent-light);border-color:var(--accent-border);color:var(--accent);font-weight:500}
.modal-footer{padding:10px 20px 20px;border-top:1px solid var(--border);display:flex;gap:8px;background:rgba(242,242,247,.95);position:sticky;bottom:0}
.btn-cancel{flex:1;height:40px;border:1px solid var(--border2);background:var(--surface);border-radius:var(--rs);font-size:14px;font-family:inherit;color:var(--text2);cursor:pointer}
.btn-cancel:hover{background:rgba(118,118,128,.08)}
.btn-confirm{flex:1;height:40px;border:none;background:var(--accent);color:#fff;border-radius:var(--rs);font-size:14px;font-weight:500;font-family:inherit;cursor:pointer}
.btn-confirm:hover{opacity:.88}

/* ── STATUS MODAL EXTRA ── */
.status-sel-row{display:flex;gap:6px;margin-top:4px}
.status-opt{flex:1;height:32px;border-radius:var(--rxs);border:1.5px solid var(--border2);background:var(--surface2);cursor:pointer;font-size:12px;font-family:inherit;transition:all .14s;color:var(--text2)}
.status-opt.active-todo{border-color:var(--s-todo);background:rgba(142,142,147,.12);color:var(--s-todo);font-weight:500}
.status-opt.active-doing{border-color:var(--s-doing);background:var(--accent-light);color:var(--s-doing);font-weight:500}
.status-opt.active-done{border-color:var(--s-done);background:rgba(52,199,89,.12);color:var(--s-done);font-weight:500}
.status-opt.active-cancel{border-color:var(--s-cancel);background:rgba(255,149,0,.12);color:var(--s-cancel);font-weight:500}
.pri-opt-row{display:flex;gap:6px}
.pri-opt{flex:1;height:32px;border-radius:var(--rxs);border:1.5px solid var(--border2);background:var(--surface2);cursor:pointer;font-size:12px;font-family:inherit;transition:all .14s;color:var(--text2)}
.pri-opt.active{border-color:var(--accent-border);background:var(--accent-light);color:var(--accent);font-weight:500}
.edit-link-row{display:flex;gap:6px;align-items:center;margin-bottom:6px}

/* ── SEARCH ── */
.search-overlay{position:fixed;inset:0;z-index:300;background:rgba(0,0,0,.5);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);animation:fadeIn .15s ease;display:flex;flex-direction:column}
.search-box{background:rgba(242,242,247,.96);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(--border);padding:12px 20px;display:flex;align-items:center;gap:10px}
.search-main-input{flex:1;height:38px;border:1px solid var(--border2);border-radius:var(--rs);background:var(--surface);padding:0 14px;font-family:inherit;font-size:15px;color:var(--text1);outline:none}
.search-cancel-btn{background:none;border:none;font-size:14px;color:var(--accent);cursor:pointer;font-family:inherit;padding:4px 2px}
.search-results{flex:1;overflow-y:auto;background:var(--bg);padding:14px 20px 40px}
.search-section-label{font-size:11px;font-weight:600;letter-spacing:.04em;text-transform:uppercase;color:var(--text3);margin:14px 0 7px}
.search-section-label:first-child{margin-top:0}
.search-result-item{background:var(--surface);border:1px solid var(--border);border-radius:var(--rs);padding:10px 14px;margin-bottom:5px;cursor:pointer;animation:fadeUp .14s var(--ease) both}
.search-result-item:hover{opacity:.82}
.search-result-title{font-size:13.5px;color:var(--text1);margin-bottom:3px}
.search-result-title mark{background:rgba(0,122,255,.14);color:var(--accent);border-radius:2px;padding:0 2px;font-style:normal}
.search-result-meta{font-size:11px;color:var(--text3);display:flex;gap:7px}
.search-empty{text-align:center;padding:48px 20px;color:var(--text3);font-size:13px}

/* ── TOAST ── */
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(10px);background:rgba(44,44,46,.92);backdrop-filter:blur(16px);color:#fff;padding:9px 18px;border-radius:20px;font-size:13px;z-index:500;opacity:0;pointer-events:none;transition:opacity .18s,transform .18s var(--spring);white-space:nowrap;box-shadow:var(--shadow-lg)}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

/* ── SETTINGS ── */
.settings-wrap{max-width:600px;margin:0 auto}
.settings-section{background:var(--surface);border-radius:var(--r);overflow:hidden;margin-bottom:12px;border:1px solid var(--border)}
.settings-section-head{padding:12px 16px 10px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px}
.settings-section-icon{font-size:14px}
.settings-section-title{font-size:13.5px;font-weight:600;color:var(--text1)}
.settings-section-desc{font-size:11px;color:var(--text3);margin-left:auto}
.settings-field{padding:10px 16px;border-bottom:1px solid var(--border)}
.settings-label{font-size:12px;font-weight:500;color:var(--text2);margin-bottom:5px;display:flex;align-items:center;gap:5px}
.settings-label-hint{font-size:11px;color:var(--text4)}
.settings-input{width:100%;height:38px;padding:0 12px;border:1px solid var(--border2);border-radius:var(--rs);background:var(--surface);font-family:inherit;font-size:13.5px;color:var(--text1);outline:none}
.settings-input:focus{border-color:var(--accent-border);box-shadow:0 0 0 3px var(--accent-light)}
.settings-input::placeholder{color:var(--text4)}
.settings-btn-row{display:flex;gap:7px;flex-wrap:wrap;padding:10px 16px}
.settings-btn{height:34px;padding:0 16px;border-radius:17px;border:none;font-family:inherit;font-size:12.5px;font-weight:500;cursor:pointer}
.settings-btn.primary{background:var(--accent);color:#fff}
.settings-btn.ghost{background:rgba(118,118,128,.1);color:var(--text2);border:1px solid var(--border2)}
.settings-btn.danger{background:rgba(255,59,48,.08);color:var(--del);border:1px solid rgba(255,59,48,.2)}
.settings-btn:hover{opacity:.82}
.sync-status-row{display:flex;align-items:center;gap:8px;padding:9px 16px;font-size:12px;color:var(--text2);border-top:1px solid var(--border)}
.sync-dot{width:7px;height:7px;border-radius:50%;background:var(--surface4);flex-shrink:0}
.sync-dot.ok{background:var(--done)}.sync-dot.err{background:var(--del)}.sync-dot.syncing{background:var(--accent);animation:pulse 1s ease infinite}
.settings-info{font-size:12px;color:var(--text3);line-height:1.65;padding:9px 16px;background:rgba(118,118,128,.04);border-top:1px solid var(--border)}
.settings-info a{color:var(--accent);text-decoration:none}
.task-item.pinned{background:#fffbf0;border-color:rgba(255,149,0,.25)}
.task-act-btn.pin-btn.active{color:var(--warn)}
.k-create-hint{text-align:center;padding:10px 0 6px;font-size:12px;color:var(--text4);cursor:pointer;border-radius:var(--rxs);transition:background .12s,color .12s;margin-top:2px}
