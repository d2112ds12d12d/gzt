function handleImagePaste(e,noteId){
  var items=e.clipboardData&&e.clipboardData.items;if(!items)return;
  for(var i=0;i<items.length;i++){
    if(items[i].type.indexOf('image')!==-1){
      e.preventDefault();
      compressImage(items[i].getAsFile(),function(dataUrl){
        var note=S.notes.find(function(n){return n.id===noteId;});if(!note)return;
        if(!note.images)note.images=[];note.images.push(dataUrl);save();
        var wrap=eid('nd-imgs-'+noteId);
        if(wrap)wrap.outerHTML=renderNoteImages(note,noteId);
        else{var bw=eid('nd-bodywrap-'+noteId);if(bw)bw.insertAdjacentHTML('beforeend',renderNoteImages(note,noteId));}
        toast('图片已添加 ✓');
      });return;
    }
  }
}
