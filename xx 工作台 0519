      (!t.done?'<button class="task-act-btn pin-btn'+(pinned?' active':'')+'" onclick="togglePin(\''+t.id+'\',event)" title="'+(pinned?'取消置顶':'置顶')+'"><i class="ti ti-pin" style="font-size:13px"></i></button>':'')+
      '<button class="task-act-btn" onclick="openEditTask(\''+t.id+'\')" title="编辑"><i class="ti ti-edit" style="font-size:13px"></i></button>'+
