  var ib=eid('sb-inbox-badge');if(ib){ib.style.display=ic>0?'':'none';ib.textContent=ic;}
  var tib=eid('toolbar-inbox-badge');if(tib){tib.style.display=ic>0?'':'none';tib.textContent=ic;}
  var cib=eid('inbox-count-badge');if(cib){cib.style.display=ic>0?'':'none';cib.textContent=ic;}
}

/* ══════════════════════════════════
   MIDNIGHT REFRESH
══════════════════════════════════ */
function scheduleMidnightRefresh(){
  var now=new Date();
  var midnight=new Date(now.getFullYear(),now.getMonth(),now.getDate()+1,0,0,5);
  setTimeout(function(){generateRecurringTasks();renderAll();scheduleMidnightRefresh();},midnight-now);
}

/* ══════════════════════════════════
   RENDER ALL
══════════════════════════════════ */
function renderAll(){
  renderGreeting();renderTodayTasks();renderAllTasks();renderNotes();renderReviewPage();renderBooks();updateSidebar();
}

/* ══════════════════════════════════
   INIT
══════════════════════════════════ */
function init(){
  load();
  var now=new Date();
  var dateStr=now.toLocaleDateString('zh-CN',{year:'numeric',month:'long',day:'numeric',weekday:'long'});
  eid('topbar-date').textContent=dateStr;
  eid('sb-date').textContent=now.toLocaleDateString('zh-CN',{month:'long',day:'numeric',weekday:'short'});
  generateRecurringTasks();
  initCollapsedDates();
  renderAll();
  // today tab: show view-seg, hide task-only filters
  eid('toolbar-add-btn').onclick=function(){openAddTaskForDate(todayStr());};
  ['toolbar-sep2','toolbar-filters','toolbar-sep1'].forEach(function(id){var el=eid(id);if(el)el.style.display='none';});
  eid('view-seg').style.display='';
  eid('toolbar-sep3').style.display='';
  S.todayView='list';
  setTodayView('list');
  scheduleMidnightRefresh();
  eid('capture-input').addEventListener('keydown',function(e){if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();submitCapture();}});
}
window.addEventListener('DOMContentLoaded',init);
</script>
