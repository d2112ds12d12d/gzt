══════════════════════════════════ */
var _dragTaskId=null;
var _dragType=null; // 'kanban' | 'matrix'

function onCardDragStart(e,taskId,type){
  _dragTaskId=taskId;
  _dragType=type;
  e.dataTransfer.effectAllowed='move';
  e.dataTransfer.setData('text/plain',taskId);
  // slight delay so browser snapshot doesn't show half-transparent
  setTimeout(function(){
    var el=document.getElementById('kc-'+taskId)||document.getElementById('mx-'+taskId);
    if(el)el.classList.add('dragging');
  },0);
}

function onCardDragEnd(e,taskId){
  var el=document.getElementById('kc-'+taskId)||document.getElementById('mx-'+taskId);
  if(el)el.classList.remove('dragging');
  // clear all drag-over highlights
  document.querySelectorAll('.k-body.drag-over,.mx-cell.drag-over').forEach(function(el){el.classList.remove('drag-over');});
  _dragTaskId=null;_dragType=null;
}

function onKanbanBodyDragOver(e,statusId){
  if(_dragType!=='kanban')return;
  e.preventDefault();
  e.dataTransfer.dropEffect='move';
  document.querySelectorAll('.k-body').forEach(function(el){el.classList.remove('drag-over');});
  e.currentTarget.classList.add('drag-over');
}

function onKanbanBodyDragLeave(e){
  e.currentTarget.classList.remove('drag-over');
}

function onKanbanBodyDrop(e,statusId){
  e.preventDefault();
  e.currentTarget.classList.remove('drag-over');
  if(!_dragTaskId)return;
  var t=S.tasks.find(function(x){return x.id===_dragTaskId;});
  if(!t)return;
  if(t.status===statusId)return; // no change
  t.status=statusId;
  t.done=statusId==='done';
  save();
  // re-render whichever kanban is visible
  if(S.currentTab==='today')renderTodayKanban();
  else renderKanban();
  renderTodayTasks();updateSidebar();
  toast('已移至「'+STATUS_LABELS[statusId]+'」');
}

function onMatrixCellDragOver(e,pri){
  if(_dragType!=='matrix')return;
  e.preventDefault();
  e.dataTransfer.dropEffect='move';
  document.querySelectorAll('.mx-cell').forEach(function(el){el.classList.remove('drag-over');});
  e.currentTarget.classList.add('drag-over');
}

function onMatrixCellDragLeave(e){
  e.currentTarget.classList.remove('drag-over');
}

function onMatrixCellDrop(e,pri){
  e.preventDefault();
  e.currentTarget.classList.remove('drag-over');
  if(!_dragTaskId)return;
  var t=S.tasks.find(function(x){return x.id===_dragTaskId;});
  if(!t)return;
  if((t.priority||'normal')===pri)return;
  t.priority=pri;
  save();
  if(S.currentTab==='today')renderTodayMatrix();
  else renderMatrix();
  toast('优先级已更新为「'+PRI_LABELS[pri]+'」');
}


function renderKanbanInto(el,tasks,scope){
  var STATUS_CONFIG=[
    {id:'todo',label:'未开始',color:'#8e8e93'},
    {id:'doing',label:'进行中',color:'#007aff'},
    {id:'done',label:'已完成',color:'#34c759'},
    {id:'cancel',label:'已取消',color:'#ff9500'}
  ];
  var date=scope==='today'?todayStr():'';
  el.innerHTML=STATUS_CONFIG.map(function(sc){
    var cols=tasks.filter(function(t){
      var s=t.status||'todo';
      if(sc.id==='done')return s==='done'||t.done;
      return s===sc.id;
    });
    cols=sortTasks(cols);
    var cardsHtml=cols.map(function(t){
      var overdue=!t.done&&t.status!=='cancel'&&t.date&&t.date<todayStr();
      var dateLabel=t.date===todayStr()?'今天':t.date||'';
      return'<div class="k-card'+(t.done?' done':'')+'" id="kc-'+t.id+'"'+
        ' draggable="true"'+
        ' ondragstart="onCardDragStart(event,\''+t.id+'\',\'kanban\')"'+
        ' ondragend="onCardDragEnd(event,\''+t.id+'\')"'+
        ' onclick="openEditTask(\''+t.id+'\')"'+
        '>'+
        '<button class="k-card-del" onclick="deleteTask(\''+t.id+'\',event)" title="删除">×</button>'+
        '<div class="k-card-title">'+(t.pinned&&!t.done?'<span style="font-size:11px;margin-right:2px">📌</span>':'')+esc(t.title)+'</div>'+
        '<div class="k-card-meta">'+
          (t.tag?'<span class="k-card-tag">'+esc(t.tag)+'</span>':'')+
          '<span class="k-card-pri">'+PRI_LABELS[t.priority||'normal']+'</span>'+
          (dateLabel?'<span class="k-card-date'+(overdue?' overdue':'')+'">'+dateLabel+'</span>':'')+
        '</div>'+
      '</div>';
    }).join('');
    // click-to-create area
    var createHint='<div class="k-create-hint" onclick="openAddTaskWithStatus(\''+sc.id+'\''+(date?',\''+date+'\'':'')+')">＋ 新建任务</div>';
    return'<div class="k-col">'+
      '<div class="k-col-bar" style="background:'+sc.color+'"></div>'+
      '<div class="k-head"><div class="k-dot" style="background:'+sc.color+'"></div><span class="k-label">'+sc.label+'</span><span class="k-count">'+cols.length+'</span></div>'+
      '<div class="k-body"'+
        ' ondragover="onKanbanBodyDragOver(event,\''+sc.id+'\')"'+
        ' ondragleave="onKanbanBodyDragLeave(event)"'+
        ' ondrop="onKanbanBodyDrop(event,\''+sc.id+'\')"'+
        ' onclick="handleKanbanBodyClick(event,\''+sc.id+'\''+(date?',\''+date+'\'':'')+')">'+
        cardsHtml+createHint+
      '</div>'+
    '</div>';
  }).join('');
}

function handleKanbanBodyClick(e,statusId,date){
  // only fire if clicking directly on k-body (not on a card)
  if(e.target.classList.contains('k-body'))openAddTaskWithStatus(statusId,date);
}

function renderKanban(){
  var el=eid('kanban-columns');if(!el)return;
  renderKanbanInto(el,S.tasks.filter(function(t){return !t.isTemplate;}),'all');
}

/* ══════════════════════════════════
   MATRIX
══════════════════════════════════ */
function renderMatrixInto(el,tasks,scope){
  var date=scope==='today'?todayStr():'';
  var CELLS=[
    {id:'q1',label:'🔴 重要且紧急',pri:'urgent'},
    {id:'q2',label:'🟡 重要不紧急',pri:'important'},
    {id:'q3',label:'⚪ 普通（待分类）',pri:'normal'},
    {id:'q4',label:'· 其他',pri:'__other__'}
  ];
  var used=[];
  el.innerHTML=CELLS.map(function(c){
    var items;
    if(c.pri==='__other__'){
      items=tasks.filter(function(t){return used.indexOf(t.id)===-1;});
    } else {
      items=tasks.filter(function(t){return (t.priority||'normal')===c.pri&&used.indexOf(t.id)===-1;});
    }
    items.forEach(function(t){used.push(t.id);});
    var priForNew=c.pri==='__other__'?'normal':c.pri;
    var itemsHtml=items.map(function(t){
      return'<div class="mx-item'+(t.done?' done':'')+'" id="mx-'+t.id+'"'+
        ' draggable="true"'+
        ' ondragstart="onCardDragStart(event,\''+t.id+'\',\'matrix\')"'+
        ' ondragend="onCardDragEnd(event,\''+t.id+'\')"'+
        ' onclick="openEditTask(\''+t.id+'\')"'+
        '>'+
        '<button class="mx-item-del" onclick="deleteTask(\''+t.id+'\',event)" title="删除">×</button>'+
        '<div class="mx-item-title">'+esc(t.title)+'</div>'+
        '<div class="mx-item-meta">'+
          (t.tag?'<span class="mx-item-tag">'+esc(t.tag)+'</span>':'')+
          '<span class="mx-item-st">'+STATUS_LABELS[t.status||'todo']+'</span>'+
        '</div>'+
      '</div>';
    }).join('');
    var createHint='<div class="mx-create-hint" onclick="openAddTaskWithPri(\''+priForNew+'\''+(date?',\''+date+'\'':'')+')">＋ 新建任务</div>';
    return'<div class="mx-cell '+c.id+'"'+
      ' ondragover="onMatrixCellDragOver(event,\''+priForNew+'\')"'+
      ' ondragleave="onMatrixCellDragLeave(event)"'+
      ' ondrop="onMatrixCellDrop(event,\''+priForNew+'\')"'+
      ' onclick="handleMatrixCellClick(event,\''+priForNew+'\''+(date?',\''+date+'\'':'')+')">'+
      '<div class="mx-hdr">'+c.label+'</div>'+
      '<div class="mx-items">'+itemsHtml+createHint+'</div>'+
    '</div>';
  }).join('');
}

function handleMatrixCellClick(e,pri,date){
  if(e.target.classList.contains('mx-cell')||e.target.classList.contains('mx-items'))openAddTaskWithPri(pri,date);
}

function renderMatrix(){
  var el=eid('matrix-grid');if(!el)return;
  var tasks=S.tasks.filter(function(t){return !t.isTemplate&&!t.done&&t.status!=='done'&&t.status!=='cancel';});
  renderMatrixInto(el,tasks,'all');
}

/* ══════════════════════════════════
   TOGGLE TASK
══════════════════════════════════ */
function toggleTask(id){
  var t=S.tasks.find(function(x){return x.id===id;});if(!t)return;
  var wasDone=t.done;
  t.done=!t.done;
  if(t.done)t.status='done';
  else t.status='todo';
  save();
  renderTodayTasks();renderAllTasks();renderGreeting();updateSidebar();
  if(!wasDone&&t.done)showFollowUpBar(t);
}

/* ══════════════════════════════════
   FOLLOW-UP BAR
══════════════════════════════════ */
var _fuTimer=null;
function showFollowUpBar(task){
  clearTimeout(_fuTimer);
  var existing=document.getElementById('followup-bar');if(existing)existing.remove();
  var bar=document.createElement('div');
  bar.id='followup-bar';bar.className='followup-bar';
  bar.innerHTML=
    '<div class="followup-bar-text">✓ 完成「'+esc(task.title)+'」</div>'+
    '<div style="display:flex;gap:6px;flex-shrink:0">'+
      '<button class="followup-btn followup-btn-yes" onclick="startFollowUp(\''+task.id+'\',\''+esc(task.title).replace(/'/g,'\\\'').replace(/"/g,'&quot;')+'\',\''+task.date+'\')">记录跟进</button>'+
      '<button class="followup-btn followup-btn-next" onclick="createNextTask(\''+task.id+'\')">创建下一步</button>'+
      '<button class="followup-btn followup-btn-no" onclick="dismissFollowUp()">忽略</button>'+
    '</div>';
  document.body.appendChild(bar);
  _fuTimer=setTimeout(dismissFollowUp,8000);
}
function dismissFollowUp(){
  var b=document.getElementById('followup-bar');
  if(b){b.style.opacity='0';b.style.transform='translateX(-50%) translateY(10px)';setTimeout(function(){if(b.parentNode)b.remove();},200);}
}
function startFollowUp(taskId,taskTitle,taskDate){
  dismissFollowUp();
  var note={id:uid(),title:'跟进：'+taskTitle+' · '+(taskDate||todayStr()),body:'',cat:'followup',date:nowStr(),created:Date.now()};
  S.notes.unshift(note);save();
  switchTab('notes');
  setTimeout(function(){openNoteDetail(note.id);},150);
}
function createNextTask(parentId){
  dismissFollowUp();
  var parent=S.tasks.find(function(x){return x.id===parentId;});
  S._modalAction='addNextTask';
  S._nextTaskParentId=parentId;
  S._editTaskTag=parent?parent.tag||null:null;
  S._editTaskStatus='todo';S._editTaskPri=parent?parent.priority||'normal':'normal';
  _editLinks=[];
  eid('modal-title').textContent='创建下一步任务';
  eid('modal-body').innerHTML=
    (parent?'<div style="font-size:12px;color:var(--text3);margin-bottom:12px;padding:8px 12px;background:var(--surface2);border-radius:var(--rxs)">上一步：'+esc(parent.title)+'</div>':'')+
    '<div class="modal-field"><label class="modal-label">任务名称</label><input class="modal-input" id="edit-task-title" placeholder="下一步要做什么？" /></div>'+
    '<div class="modal-field"><label class="modal-label">日期</label><input class="modal-input" id="edit-task-date" value="'+todayStr()+'" placeholder="MM/DD" /></div>'+
    '<div class="modal-field"><label class="modal-label">标签</label><div class="modal-tag-row">'+
      TAGS.map(function(tg){return'<button class="modal-tag-opt'+(S._editTaskTag===tg?' selected':'')+'" onclick="modalSelectTag(\''+tg+'\',this)">'+tg+'</button>';}).join('')+
    '</div></div>';
  eid('modal-overlay').style.display='flex';
  setTimeout(function(){var el=eid('edit-task-title');if(el)el.focus();},80);
}

function deleteTask(id,e){
  if(e)e.stopPropagation();
  S.tasks=S.tasks.filter(function(t){return t.id!==id;});
  S.deletedIds.push(id);save();
  renderTodayTasks();renderAllTasks();renderGreeting();updateSidebar();
  toast('任务已删除');
}

function openTaskImagePreview(taskId,idx,e){
  if(e)e.stopPropagation();
  var t=S.tasks.find(function(x){return x.id===taskId;});
  if(!t||!t.images||!t.images[idx])return;
  var ov=document.createElement('div');
  ov.style.cssText='position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:600;display:flex;align-items:center;justify-content:center;cursor:zoom-out';
  ov.onclick=function(){ov.remove();};
  var img=document.createElement('img');
  img.src=t.images[idx];img.style.cssText='max-width:92vw;max-height:92vh;border-radius:8px';
  ov.appendChild(img);document.body.appendChild(ov);
}

