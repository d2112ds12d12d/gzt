/* ══════════════════════════════════
   DATE PARSING
══════════════════════════════════ */
function parseNaturalDate(text){
  var now=new Date();
  var map={'今天':0,'今日':0,'明天':1,'明日':1,'后天':2,'大后天':3};
  var wm={'下周一':1,'下周二':2,'下周三':3,'下周四':4,'下周五':5,'下周六':6,'下周日':0,'下周天':0};
  for(var k in map){if(text.indexOf(k)!==-1){var d=new Date(now);d.setDate(d.getDate()+map[k]);return pad(d.getMonth()+1)+'/'+pad(d.getDate());}}
  for(var k in wm){if(text.indexOf(k)!==-1){var t=wm[k],dy=now.getDay(),df=(t-dy+7)%7;if(df===0)df=7;var d=new Date(now);d.setDate(d.getDate()+df);return pad(d.getMonth()+1)+'/'+pad(d.getDate());}}
  var m=text.match(/(\d{1,2})[\/月](\d{1,2})[日号]?/);
  if(m)return pad(parseInt(m[1]))+'/'+pad(parseInt(m[2]));
  return null;
}
function stripDateKW(text){return text.replace(/(今天|今日|明天|明日|后天|大后天|下周[一二三四五六日天]|\d{1,2}[\/月]\d{1,2}[日号]?)/g,'').trim();}
var _parsedDate=null;
function onCaptureInput(el){
  autoResize(el);
  _parsedDate=parseNaturalDate(el.value);
  eid('date-preview').innerHTML=_parsedDate?'<span class="date-chip">📅 '+(_parsedDate===todayStr()?'今天 · ':'')+_parsedDate+'</span>':'';
}

