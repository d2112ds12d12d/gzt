    '</div>'+
  '</div>';
}

function sortTasks(tasks){
  return tasks.slice().sort(function(a,b){
    var aDone=!!(a.done||a.status==='done'||a.status==='cancel');
    var bDone=!!(b.done||b.status==='done'||b.status==='cancel');
    if(aDone!==bDone)return aDone?1:-1;
    // pinned undone float to top
    var aPin=!!a.pinned&&!aDone,bPin=!!b.pinned&&!bDone;
    if(aPin!==bPin)return aPin?-1:1;
    // pri order: urgent > important > normal
    var priOrder={urgent:0,important:1,normal:2};
    var ap=priOrder[a.priority]||2,bp=priOrder[b.priority]||2;
    if(ap!==bp)return ap-bp;
    return b.created-a.created;
  });
}

function togglePin(id,e){
  if(e)e.stopPropagation();
  var t=S.tasks.find(function(x){return x.id===id;});if(!t)return;
  t.pinned=!t.pinned;
  save();renderTodayTasks();renderAllTasks();
  toast(t.pinned?'已置顶 📌':'已取消置顶');
}

