/* ══════════════════════════════════
   DATA ANALYSIS
══════════════════════════════════ */
function renderAnalysis(){
  var el=eid('an-kpis');if(!el)return;
  var tasks=S.tasks.filter(function(t){return !t.isTemplate;});
  var total=tasks.length;
  var done=tasks.filter(function(t){return t.done||t.status==='done';}).length;
  var today=todayStr();
  var todayTasks=tasks.filter(function(t){return t.date===today;});
  var todayDone=todayTasks.filter(function(t){return t.done||t.status==='done';}).length;
  var rate=total>0?Math.round(done/total*100):0;
  var inboxCount=S.inbox.length;
  el.innerHTML=
    kpiCard('总任务',''+total,'共 '+done+' 已完成')+
    kpiCard('完成率',rate+'%',done+' / '+total)+
    kpiCard('今日完成',todayDone+'',todayTasks.length?'今日共 '+todayTasks.length+' 条':'今日暂无任务')+
    kpiCard('收集箱',inboxCount+'','待整理');

  var chartEl=eid('an-charts');if(!chartEl)return;
  // tag distribution
  var tagMap={};
  tasks.forEach(function(t){var tg=t.tag||'无标签';if(!tagMap[tg])tagMap[tg]=0;tagMap[tg]++;});
  var tags=Object.keys(tagMap).sort(function(a,b){return tagMap[b]-tagMap[a];}).slice(0,6);
  var maxTag=tags.length?tagMap[tags[0]]:1;
  var tagBars=tags.map(function(tg){
    var w=Math.round(tagMap[tg]/maxTag*100);
    return'<div class="an-bar-row">'+
      '<div class="an-bar-label" title="'+esc(tg)+'">'+esc(tg)+'</div>'+
      '<div class="an-bar-track"><div class="an-bar-fill" style="width:'+w+'%;background:var(--accent)"></div></div>'+
      '<div class="an-bar-count">'+tagMap[tg]+'</div>'+
    '</div>';
  }).join('');

  // status distribution
  var statusMap={todo:0,doing:0,done:0,cancel:0};
  tasks.forEach(function(t){var s=t.done?'done':t.status||'todo';statusMap[s]=(statusMap[s]||0)+1;});
  var statusColors={todo:'var(--s-todo)',doing:'var(--s-doing)',done:'var(--s-done)',cancel:'var(--s-cancel)'};
  var maxSt=Math.max.apply(null,Object.values(statusMap))||1;
  var stBars=Object.keys(statusMap).map(function(s){
    var w=Math.round(statusMap[s]/maxSt*100);
    return'<div class="an-bar-row">'+
      '<div class="an-bar-label">'+STATUS_LABELS[s]+'</div>'+
      '<div class="an-bar-track"><div class="an-bar-fill" style="width:'+w+'%;background:'+statusColors[s]+'"></div></div>'+
      '<div class="an-bar-count">'+statusMap[s]+'</div>'+
    '</div>';
  }).join('');

  // week completed
  var weekData=[];
  for(var i=6;i>=0;i--){
    var d=new Date();d.setDate(d.getDate()-i);
    var ds=pad(d.getMonth()+1)+'/'+pad(d.getDate());
    var cnt=tasks.filter(function(t){return t.date===ds&&(t.done||t.status==='done');}).length;
    weekData.push({label:['日','一','二','三','四','五','六'][d.getDay()],cnt:cnt,isToday:i===0});
  }
  var maxW=Math.max.apply(null,weekData.map(function(x){return x.cnt;}))||1;
  var weekBars=weekData.map(function(x){
    var h=Math.max(Math.round(x.cnt/maxW*80),x.cnt>0?4:2);
    return'<div class="an-week-col">'+
      '<div class="an-week-val">'+x.cnt+'</div>'+
      '<div class="an-week-bar'+(x.isToday?' today':'')+'" style="height:'+h+'px"></div>'+
      '<div class="an-week-label">'+x.label+'</div>'+
    '</div>';
  }).join('');

  chartEl.innerHTML=
    '<div class="an-card"><div class="an-card-title">标签分布</div>'+(tagBars||'<div style="color:var(--text4);font-size:12px">暂无数据</div>')+'</div>'+
    '<div class="an-card"><div class="an-card-title">状态分布</div>'+stBars+'</div>'+
    '<div class="an-card" style="grid-column:1/-1"><div class="an-card-title">近7天完成任务</div><div class="an-week-bars">'+weekBars+'</div></div>';
}
function kpiCard(label,val,sub){
  return'<div class="an-kpi"><div class="an-kpi-label">'+label+'</div><div class="an-kpi-val">'+val+'</div><div class="an-kpi-sub">'+sub+'</div></div>';
}

