var URL_RE=/https?:\/\/[^\s]+/g;
function submitCapture(){
  var inp=eid('capture-input'),raw=inp.value.trim();if(!raw)return;
  var date=_parsedDate||todayStr();
  var title=_parsedDate?stripDateKW(raw)||raw:raw;
  var urls=title.match(URL_RE)||[];
  var cleanTitle=urls.length?title.replace(URL_RE,'').trim():title;
  var links=urls.map(function(u){return{url:u,text:u};});
  var task={id:uid(),title:cleanTitle||title,tag:S.selectedTag,date:date,done:false,status:'todo',priority:'normal',created:Date.now()};
  if(links.length)task.links=links;
  S.tasks.unshift(task);save();
  inp.value='';inp.style.height='auto';eid('date-preview').innerHTML='';_parsedDate=null;S.selectedTag=null;
  renderCaptureTags();renderTodayTasks();renderGreeting();updateSidebar();
  toast(date===todayStr()?'已添加到今日 ✓':'已添加到 '+date+' ✓');
}
