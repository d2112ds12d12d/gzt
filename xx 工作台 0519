function hl(text,q){if(!q)return esc(text);var re=new RegExp('('+q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')+')','gi');return esc(text).replace(re,'<mark>$1</mark>');}
function runSearch(q){
  var el=eid('search-results');q=q.trim();
  if(!q){el.innerHTML='<div class="search-empty"><div style="font-size:32px;margin-bottom:10px">🔍</div><p>输入关键词开始搜索</p></div>';return;}
  var ql=q.toLowerCase();
  var tasks=S.tasks.filter(function(t){return !t.isTemplate&&(t.title.toLowerCase().indexOf(ql)!==-1||(t.note||'').toLowerCase().indexOf(ql)!==-1);});
  var notes=S.notes.filter(function(n){return(n.title||'').toLowerCase().indexOf(ql)!==-1||(n.body||'').toLowerCase().indexOf(ql)!==-1;});
  var books=S.books.filter(function(b){return b.title.toLowerCase().indexOf(ql)!==-1||(b.author||'').toLowerCase().indexOf(ql)!==-1;});
  var html='';
  if(tasks.length){
    html+='<div class="search-section-label">任务</div>'+tasks.slice(0,8).map(function(t){
      return'<div class="search-result-item" onclick="closeSearch();switchTab(\'tasks\');setTimeout(function(){openEditTask(\''+t.id+'\')},200)">'+
        '<div class="search-result-title">'+hl(t.title,q)+'</div>'+
        '<div class="search-result-meta"><span>'+t.date+'</span><span>'+STATUS_LABELS[t.status||'todo']+'</span></div>'+
      '</div>';
    }).join('');
  }
  if(notes.length){
    html+='<div class="search-section-label">笔记</div>'+notes.slice(0,5).map(function(n){
      var tab=n.cat==='review'?'review':'notes';
      return'<div class="search-result-item" onclick="closeSearch();switchTab(\''+tab+'\');setTimeout(function(){'+(n.cat==='review'?'openReviewDetail':'openNoteDetail')+'(\''+n.id+'\')},200)">'+
        '<div class="search-result-title">'+hl(n.title||'（无标题）',q)+'</div>'+
        '<div class="search-result-meta"><span>'+n.date+'</span></div>'+
      '</div>';
    }).join('');
  }
  if(books.length){
    html+='<div class="search-section-label">读书</div>'+books.slice(0,5).map(function(b){
      return'<div class="search-result-item" onclick="closeSearch();switchTab(\'books\');setTimeout(function(){openBookDetail(\''+b.id+'\')},200)">'+
        '<div class="search-result-title">'+hl(b.title,q)+(b.author?' — '+esc(b.author):'')+'</div>'+
        '<div class="search-result-meta"><span>'+(b.notes||[]).length+'条笔记</span></div>'+
      '</div>';
    }).join('');
  }
  if(!html)html='<div class="search-empty"><div style="font-size:32px;margin-bottom:10px">🔍</div><p>没有找到 "'+esc(q)+'" 相关内容</p></div>';
  el.innerHTML=html;
}
