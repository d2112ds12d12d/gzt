<script>
/* ══════════════════════════════════
   STATE
══════════════════════════════════ */
var S={
  tasks:[],books:[],notes:[],inbox:[],deletedIds:[],
  selectedTag:null,taskFilter:'all',taskView:'list',
  currentTab:'today',_modalAction:null,_editingTaskId:null,
  _noteFilter:'all',_batchSelected:{},_nextTaskParentId:null
};
var TAGS=['工作','学习','生活','其他'];
var NOTE_CATS=[
  {id:'experience',label:'经验'},{id:'method',label:'方法'},
  {id:'idea',label:'想法'},{id:'followup',label:'跟进'},{id:'other',label:'其他'}
];
var SPINE_COLORS=['#eff6ff','#fef9c3','#f0fdf4','#fdf4ff','#fff7ed','#f0f9ff'];
var STATUS_LABELS={todo:'未开始',doing:'进行中',done:'已完成',cancel:'已取消'};
var PRI_LABELS={normal:'⚪ 普通',important:'🟡 重要',urgent:'🔴 紧急'};
var _editLinks=[];

/* ══════════════════════════════════
   HOLIDAYS (CN)
══════════════════════════════════ */
var HOLIDAYS={'2025-01-01':1,'2025-01-28':1,'2025-01-29':1,'2025-01-30':1,'2025-01-31':1,'2025-02-01':1,'2025-02-02':1,'2025-02-03':1,'2025-02-04':1,'2025-04-04':1,'2025-04-05':1,'2025-04-06':1,'2025-05-01':1,'2025-05-02':1,'2025-05-03':1,'2025-05-04':1,'2025-05-05':1,'2025-05-31':1,'2025-06-01':1,'2025-06-02':1,'2025-10-01':1,'2025-10-02':1,'2025-10-03':1,'2025-10-04':1,'2025-10-05':1,'2025-10-06':1,'2025-10-07':1,'2025-10-08':1,'2026-01-01':1,'2026-01-02':1,'2026-01-03':1,'2026-02-17':1,'2026-02-18':1,'2026-02-19':1,'2026-02-20':1,'2026-02-21':1,'2026-02-22':1,'2026-02-23':1,'2026-04-05':1,'2026-04-06':1,'2026-05-01':1,'2026-05-02':1,'2026-05-03':1,'2026-05-04':1,'2026-05-05':1,'2026-06-19':1,'2026-06-20':1,'2026-06-21':1,'2026-10-01':1,'2026-10-02':1,'2026-10-03':1,'2026-10-04':1,'2026-10-05':1,'2026-10-06':1,'2026-10-07':1,'2026-10-08':1};
var MAKEUP={'2025-01-26':1,'2025-02-08':1,'2025-04-27':1,'2025-05-10':1,'2025-09-28':1,'2026-02-15':1,'2026-02-28':1,'2026-04-26':1,'2026-05-09':1,'2026-09-27':1};

/* ══════════════════════════════════
   UTILS
══════════════════════════════════ */
function eid(id){return document.getElementById(id);}
function uid(){return Date.now().toString(36)+Math.random().toString(36).slice(2,5);}
function esc(s){var d=document.createElement('div');d.textContent=s;return d.innerHTML;}
function pad(n){return n<10?'0'+n:String(n);}
function todayStr(){var n=new Date();return pad(n.getMonth()+1)+'/'+pad(n.getDate());}
function nowStr(){var n=new Date();return pad(n.getMonth()+1)+'/'+pad(n.getDate())+' '+pad(n.getHours())+':'+pad(n.getMinutes());}
function tomorrowStr(){var d=new Date();d.setDate(d.getDate()+1);return pad(d.getMonth()+1)+'/'+pad(d.getDate());}
function toast(msg,dur){var t=eid('toast');t.textContent=msg;t.classList.add('show');clearTimeout(t._t);t._t=setTimeout(function(){t.classList.remove('show');},dur||1800);}
function autoResize(el){el.style.height='auto';el.style.height=Math.min(el.scrollHeight,120)+'px';}

function isWorkday(d){
  var k=d.getFullYear()+'-'+pad(d.getMonth()+1)+'-'+pad(d.getDate());
  if(MAKEUP[k])return true;
  if(HOLIDAYS[k])return false;
  var dw=d.getDay();return dw!==0&&dw!==6;
}

/* ══════════════════════════════════
   STORAGE & SYNC
══════════════════════════════════ */
function getCfg(){try{return JSON.parse(localStorage.getItem('ws_cfg')||'{}');}catch(e){return {};}}
function saveCfg(c){localStorage.setItem('ws_cfg',JSON.stringify(c));}
function isConfigured(){var c=getCfg();return !!(c.owner&&c.repo&&c.token);}
function saveLocal(){
  try{localStorage.setItem('ws_v4',JSON.stringify({tasks:S.tasks,books:S.books,notes:S.notes,inbox:S.inbox,deletedIds:S.deletedIds}));}catch(e){}
}
function loadLocal(){
  try{
    var d=JSON.parse(localStorage.getItem('ws_v4')||'{}');
    S.tasks=d.tasks||[];S.books=d.books||[];S.notes=d.notes||[];S.inbox=d.inbox||[];S.deletedIds=d.deletedIds||[];
  }catch(e){}
}
function mergeData(remote){
  var allDel=S.deletedIds.slice();
  (remote.deletedIds||[]).forEach(function(id){if(allDel.indexOf(id)===-1)allDel.push(id);});
  S.deletedIds=allDel;
  function mergeColl(local,remote){
    var map={};
    local.forEach(function(x){map[x.id]=x;});
    (remote||[]).forEach(function(rx){
      if(allDel.indexOf(rx.id)!==-1)return;
      if(!map[rx.id]||rx.created>map[rx.id].created)map[rx.id]=rx;
    });
    return Object.values(map).filter(function(x){return allDel.indexOf(x.id)===-1;});
  }
  S.tasks=mergeColl(S.tasks,remote.tasks);
  S.notes=mergeColl(S.notes,remote.notes);
  S.inbox=mergeColl(S.inbox,remote.inbox||[]);
  if(remote.books&&remote.books.length)S.books=remote.books;
  saveLocal();
}
var GH_FILE='workspace-data.json';
var _syncTimer=null,_ghSha=null;
function ghHeaders(){var c=getCfg();return{'Authorization':'token '+c.token,'Content-Type':'application/json','Accept':'application/vnd.github.v3+json'};}
function ghUrl(){var c=getCfg();return'https://api.github.com/repos/'+c.owner+'/'+c.repo+'/contents/'+GH_FILE;}
function setSyncStatus(state,msg){
  var dot=eid('sync-dot'),msgEl=eid('sync-msg'),st=eid('sync-status-text');
  if(dot)dot.className='sync-dot'+(state?' '+state:'');
  if(msgEl)msgEl.textContent=msg||'';
  if(st)st.textContent=state==='ok'?'已同步':state==='err'?'同步失败':state==='syncing'?'同步中…':'未配置';
}
async function ghPull(){
  if(!isConfigured())return null;
  try{
    var r=await fetch(ghUrl(),{headers:ghHeaders()});
    if(r.status===404){_ghSha=null;return'notfound';}
    if(!r.ok)throw new Error('HTTP '+r.status);
    var json=await r.json();_ghSha=json.sha;
    var remote=JSON.parse(decodeURIComponent(escape(atob(json.content.replace(/\n/g,'')))));
    mergeData(remote);return true;
  }catch(e){console.warn('ghPull',e);return false;}
}
async function ghPush(){
  if(!isConfigured())return;
  setSyncStatus('syncing','同步中…');
  try{
    var content=btoa(unescape(encodeURIComponent(JSON.stringify({tasks:S.tasks,books:S.books,notes:S.notes,inbox:S.inbox,deletedIds:S.deletedIds},null,2))));
    var body={message:'sync '+new Date().toISOString(),content:content};
    if(_ghSha)body.sha=_ghSha;
    var r=await fetch(ghUrl(),{method:'PUT',headers:ghHeaders(),body:JSON.stringify(body)});
    if(!r.ok){var err=await r.json();throw new Error(err.message||'HTTP '+r.status);}
    var json=await r.json();_ghSha=json.content.sha;
    setSyncStatus('ok','已同步 · '+new Date().toLocaleTimeString('zh-CN',{hour:'2-digit',minute:'2-digit'}));
  }catch(e){setSyncStatus('err','同步失败：'+e.message);}
}
function save(){saveLocal();if(isConfigured()){clearTimeout(_syncTimer);_syncTimer=setTimeout(ghPush,1500);}}
function load(){
  loadLocal();
  if(isConfigured()){
    ghPull().then(function(r){
      if(r===true){renderAll();setSyncStatus('ok','已从云端加载');}
      else if(r==='notfound'){ghPush().then(function(ok){if(ok)setSyncStatus('ok','云端数据文件已初始化');});}
      else{setSyncStatus('err','云端读取失败，使用本地数据');}
    });
  }
}

