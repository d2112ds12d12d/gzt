function openAddTask(){openAddTaskForDate(todayStr());}
function openAddTaskForDate(date){
  S._modalAction='addTask';S._editingTaskId=null;S._editTaskTag=null;S._editTaskStatus='todo';S._editTaskPri='normal';
  _editLinks=[];
  eid('modal-title').textContent='新建任务';
  eid('modal-body').innerHTML=taskModalHtml(null,date);
  eid('modal-overlay').style.display='flex';
  setTimeout(function(){var el=eid('edit-task-title');if(el)el.focus();},80);
}
function openAddTaskWithStatus(statusId,date){
  S._modalAction='addTask';S._editingTaskId=null;S._editTaskTag=null;
  S._editTaskStatus=statusId||'todo';S._editTaskPri='normal';
  _editLinks=[];
  eid('modal-title').textContent='新建任务';
  eid('modal-body').innerHTML=taskModalHtml(null,date||todayStr());
  eid('modal-overlay').style.display='flex';
  setTimeout(function(){var el=eid('edit-task-title');if(el)el.focus();},80);
}
function openAddTaskWithPri(pri,date){
  S._modalAction='addTask';S._editingTaskId=null;S._editTaskTag=null;
  S._editTaskStatus='todo';S._editTaskPri=pri||'normal';
  _editLinks=[];
  eid('modal-title').textContent='新建任务';
  eid('modal-body').innerHTML=taskModalHtml(null,date||todayStr());
  eid('modal-overlay').style.display='flex';
  setTimeout(function(){var el=eid('edit-task-title');if(el)el.focus();},80);
}
function openEditTask(id){
  var t=S.tasks.find(function(x){return x.id===id;});if(!t)return;
  S._modalAction='editTask';S._editingTaskId=id;
  S._editTaskTag=t.tag||null;S._editTaskStatus=t.status||'todo';S._editTaskPri=t.priority||'normal';
  _editLinks=(t.links||[]).map(function(l){return{url:l.url,text:l.text||l.url};});
  eid('modal-title').textContent='编辑任务';
  eid('modal-body').innerHTML=taskModalHtml(t,t.date);
  eid('modal-overlay').style.display='flex';
}
function taskModalHtml(t,date){
  var title=t?t.title:'';var note=t?t.note||'':'';
  var status=t?t.status||'todo':'todo';var pri=t?t.priority||'normal':'normal';
  var STATUSES=['todo','doing','done','cancel'];
  var PRIS=['normal','important','urgent'];
  var tagsHtml=TAGS.map(function(tg){
    var sel=(t?t.tag:S.selectedTag)===tg;
    return'<button class="modal-tag-opt'+(sel?' selected':'')+'" onclick="modalSelectTag(\''+tg+'\',this)">'+tg+'</button>';
  }).join('');
  var statusHtml=STATUSES.map(function(s){
    var active=status===s?' active-'+s:'';
    return'<button class="status-opt'+active+'" id="sopt-'+s+'" onclick="modalSelStatus(\''+s+'\')">'+STATUS_LABELS[s]+'</button>';
  }).join('');
  var priHtml=PRIS.map(function(p){
    var active=pri===p?' active':'';
    return'<button class="pri-opt'+active+'" id="popt-'+p+'" onclick="modalSelPri(\''+p+'\')">'+PRI_LABELS[p]+'</button>';
  }).join('');

  // chain: show existing parent + children
  var chainHtml='';
  if(t){
    var parentHtml='';
    if(t.parentId){
      var p=S.tasks.find(function(x){return x.id===t.parentId;});
      if(p)parentHtml='<div class="chain-item chain-parent" onclick="closeModal();setTimeout(function(){openEditTask(\''+p.id+'\')},100)">↑ 上游：'+esc(p.title)+'<span class="chain-date">'+p.date+'</span></div>';
    }
    var childrenHtml='';
    if(t.childIds&&t.childIds.length){
      childrenHtml=t.childIds.map(function(cid){
        var c=S.tasks.find(function(x){return x.id===cid;});if(!c)return'';
        return'<div class="chain-item chain-child'+(c.done?' chain-done':'')+'" onclick="closeModal();setTimeout(function(){openEditTask(\''+c.id+'\')},100)">'+(c.done?'✓ ':'→ ')+esc(c.title)+'<span class="chain-date">'+c.date+'</span></div>';
      }).join('');
    }
    if(parentHtml||childrenHtml){
      chainHtml='<div class="modal-field"><label class="modal-label">任务链</label><div class="chain-block">'+parentHtml+childrenHtml+'</div></div>';
    }
  }

  // upstream selector (only if no parent yet)
  var linkHtml='';
  if(!t||!t.parentId){
    var candidates=S.tasks.filter(function(x){return x.id!==(t?t.id:'')&&!x.isTemplate;}).slice(0,30);
    var opts='<option value="">— 不关联 —</option>'+candidates.map(function(x){
      return'<option value="'+x.id+'"'+(t&&t.parentId===x.id?' selected':'')+'>'+
        (x.done?'✓ ':'')+x.title+' ('+x.date+')'+
      '</option>';
    }).join('');
    linkHtml='<div class="modal-field"><label class="modal-label">关联上游任务 <span style="font-size:11px;color:var(--text3);font-weight:400">（选填）</span></label><select class="modal-select" id="edit-task-parent">'+opts+'</select></div>';
  }

  return'<div class="modal-field"><label class="modal-label">任务标题 *</label>'+
    '<input class="modal-input" id="edit-task-title" value="'+esc(title)+'" placeholder="输入任务名称" /></div>'+
    '<div class="modal-field"><label class="modal-label">日期</label>'+
    '<input class="modal-input" id="edit-task-date" value="'+(date||'')+'" placeholder="MM/DD，如 05/20" /></div>'+
    '<div class="modal-field"><label class="modal-label">状态</label>'+
    '<div class="status-sel-row">'+statusHtml+'</div></div>'+
    '<div class="modal-field"><label class="modal-label">优先级</label>'+
    '<div class="pri-opt-row">'+priHtml+'</div></div>'+
    '<div class="modal-field"><label class="modal-label">标签</label>'+
    '<div class="modal-tag-row">'+tagsHtml+'</div></div>'+
    '<div class="modal-field"><label class="modal-label">备注</label>'+
    '<textarea class="modal-input" id="edit-task-note" style="height:80px;resize:none;padding-top:10px" placeholder="备注（选填）">'+esc(note)+'</textarea></div>'+
    '<div class="modal-field"><label class="modal-label">链接</label>'+
    '<div id="edit-task-links">'+renderEditLinks()+'</div>'+
    '<button onclick="addEditLink()" style="height:26px;padding:0 12px;border:1px dashed var(--border2);border-radius:var(--rxs);background:transparent;font-size:12px;cursor:pointer;color:var(--text3);font-family:inherit;margin-top:4px">+ 添加链接</button></div>'+
    linkHtml+chainHtml;
}
function modalSelectTag(tag,btn){
  S._editTaskTag=tag;
  document.querySelectorAll('.modal-tag-opt').forEach(function(b){b.classList.remove('selected');});
  btn.classList.add('selected');
}
function modalSelStatus(s){
  S._editTaskStatus=s;
  document.querySelectorAll('.status-opt').forEach(function(b){
    b.className='status-opt';
    ['todo','doing','done','cancel'].forEach(function(x){b.classList.remove('active-'+x);});
  });
  var btn=eid('sopt-'+s);if(btn)btn.classList.add('active-'+s);
}
function modalSelPri(p){
  S._editTaskPri=p;
  document.querySelectorAll('.pri-opt').forEach(function(b){b.classList.remove('active');});
  var btn=eid('popt-'+p);if(btn)btn.classList.add('active');
}
function renderEditLinks(){
  return _editLinks.map(function(l,i){
    return'<div class="edit-link-row">'+
      '<input class="modal-input" style="flex:1;height:32px" value="'+esc(l.url)+'" placeholder="URL" oninput="_editLinks['+i+'].url=this.value" />'+
      '<input class="modal-input" style="width:120px;height:32px" value="'+esc(l.text||'')+'" placeholder="显示文字" oninput="_editLinks['+i+'].text=this.value" />'+
      '<button onclick="removeEditLink('+i+')" style="width:28px;height:28px;border:none;background:none;cursor:pointer;color:var(--del);font-size:16px;flex-shrink:0">×</button>'+
    '</div>';
  }).join('');
}
function addEditLink(){
  _editLinks.push({url:'',text:''});
  var el=eid('edit-task-links');if(el)el.innerHTML=renderEditLinks();
}
function removeEditLink(i){
  _editLinks.splice(i,1);
  var el=eid('edit-task-links');if(el)el.innerHTML=renderEditLinks();
}
function confirmModal(){
  if(S._modalAction==='addTask'||S._modalAction==='editTask'){
    var title=(eid('edit-task-title').value||'').trim();
    if(!title){toast('任务名称不能为空');return;}
    var date=(eid('edit-task-date').value||'').trim();
    var note=(eid('edit-task-note').value||'').trim();
    var links=_editLinks.filter(function(l){return l.url.trim();});
    if(S._modalAction==='addTask'){
      var task={id:uid(),title:title,tag:S._editTaskTag,date:date||todayStr(),done:false,status:S._editTaskStatus||'todo',priority:S._editTaskPri||'normal',note:note,created:Date.now()};
      if(links.length)task.links=links;
      // upstream
      var parentSel=eid('edit-task-parent');
      if(parentSel&&parentSel.value){
        var pid=parentSel.value;task.parentId=pid;
        var par=S.tasks.find(function(x){return x.id===pid;});
        if(par){if(!par.childIds)par.childIds=[];par.childIds.push(task.id);}
      }
      S.tasks.unshift(task);
    } else {
      var t=S.tasks.find(function(x){return x.id===S._editingTaskId;});if(!t)return;
      t.title=title;t.date=date||t.date;t.tag=S._editTaskTag;t.note=note;
      t.status=S._editTaskStatus;t.done=S._editTaskStatus==='done';
      t.priority=S._editTaskPri;t.links=links;
      // upstream
      var parentSel=eid('edit-task-parent');
      if(parentSel&&parentSel.value&&parentSel.value!==t.parentId){
        var pid=parentSel.value;t.parentId=pid;
        var par=S.tasks.find(function(x){return x.id===pid;});
        if(par){if(!par.childIds)par.childIds=[];if(par.childIds.indexOf(t.id)===-1)par.childIds.push(t.id);}
      }
    }
    save();renderTodayTasks();renderAllTasks();renderGreeting();updateSidebar();
    closeModal();toast(S._modalAction==='addTask'?'任务已添加 ✓':'已更新 ✓');
    return;
  }
  if(S._modalAction==='addNextTask'){
    var title=(eid('edit-task-title').value||'').trim();
    var date=(eid('edit-task-date').value||'').trim()||todayStr();
    if(!title){toast('请输入任务名称');return;}
    var parent=S.tasks.find(function(x){return x.id===S._nextTaskParentId;});
    var newTask={id:uid(),title:title,tag:S._editTaskTag,date:date,done:false,
      status:'todo',priority:S._editTaskPri||'normal',created:Date.now(),
      parentId:S._nextTaskParentId};
    if(parent){if(!parent.childIds)parent.childIds=[];parent.childIds.push(newTask.id);}
    S.tasks.unshift(newTask);
    save();renderTodayTasks();renderAllTasks();updateSidebar();
    closeModal();toast('下一步任务已创建 ✓');
    return;
  }
  if(S._modalAction==='addBook'){
    var title=((eid('new-book-title')||{}).value||'').trim();if(!title){toast('请输入书名');return;}
    S.books.push({id:uid(),title:title,author:((eid('new-book-author')||{}).value||'').trim(),notes:[],created:Date.now()});
    save();renderBooks();toast('书已添加 ✓');closeModal();return;
  }
  if(S._modalAction==='batchReschedule'){
    var targetDate=(eid('batch-target-date').value||'').trim();
    if(!targetDate){toast('请填写目标日期');return;}
    var ids=Object.keys(S._batchSelected).filter(function(id){return S._batchSelected[id];});
    if(!ids.length){toast('请至少选择一条任务');return;}
    ids.forEach(function(id){
      var t=S.tasks.find(function(x){return x.id===id;});
      if(t&&!t.done&&t.status!=='done')t.date=targetDate;
    });
    save();renderTodayTasks();renderAllTasks();closeModal();
    toast('已将 '+ids.length+' 条任务转移到 '+targetDate+' ✓');return;
  }
  if(S._modalAction==='recurringManager'){
    var rt=(eid('rec-title')||{}).value||'';rt=rt.trim();
    if(!rt){toast('请填写任务名称');return;}
    var type=(eid('rec-type')||{}).value||'daily';
    var repeat={type:type};
    if(type==='weekly'){var wd=eid('rec-weekday');repeat.weekday=wd?parseInt(wd.value):1;}
    if(type==='monthly'){var rd=eid('rec-day');repeat.day=rd?parseInt(rd.value):1;}
    S.tasks.push({id:uid(),title:rt,tag:null,date:'',done:false,status:'todo',priority:'normal',created:Date.now(),isTemplate:true,repeat:repeat});
    save();toast('重复任务已添加 ✓');renderRecurringList();
    if(eid('rec-title'))eid('rec-title').value='';
    generateRecurringTasks();return;
  }
  if(S._modalAction==='catManager'){closeModal();renderNotes();return;}
  if(S._modalAction==='inboxPromote'){
    var inboxId=S._inboxPromoteId;
    var item=S.inbox.find(function(x){return x.id===inboxId;});
    if(!item){closeModal();return;}
    var date=(eid('promote-date').value||'').trim()||todayStr();
    var task={id:uid(),title:item.title,tag:item.tag||null,date:date,done:false,status:'todo',priority:'normal',note:item.note||'',created:Date.now()};
    S.tasks.unshift(task);
    S.inbox=S.inbox.filter(function(x){return x.id!==inboxId;});
    S.deletedIds.push(inboxId);
    save();renderInbox();updateSidebar();renderTodayTasks();
