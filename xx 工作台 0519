function renderAllTasks(){
  if(S.taskView==='kanban'){renderKanban();return;}
  if(S.taskView==='matrix'){renderMatrix();return;}
  var el=eid('task-list-view');if(!el)return;
  var tasks=S.tasks.filter(function(t){return !t.isTemplate;});
  if(S.taskFilter==='todo')tasks=tasks.filter(function(t){return !t.done&&t.status!=='done'&&t.status!=='cancel';});
  if(S.taskFilter==='done')tasks=tasks.filter(function(t){return t.done||t.status==='done';});
  if(!tasks.length){el.innerHTML='<div class="empty-state"><div class="empty-icon">✨</div><p>暂无任务</p></div>';return;}
  var groups={};
  tasks.forEach(function(t){var d=t.date||'未分配';if(!groups[d])groups[d]=[];groups[d].push(t);});
  var today=todayStr();
  var dates=Object.keys(groups).sort(function(a,b){
    if(a==='未分配')return 1;if(b==='未分配')return -1;
    return b.localeCompare(a);
  });
  var html=dates.map(function(d){
    var isToday=d===today,isPast=d!=='未分配'&&d<today;
    var sorted=sortTasks(groups[d]);
    var label=isToday?'今天 · '+d:d;
    var undone=groups[d].filter(function(t){return !t.done&&t.status!=='done'&&t.status!=='cancel';}).length;
    var hint=isPast&&undone>0?'<span style="font-size:10px;color:var(--del);margin-left:6px">'+undone+' 未完成</span>':'';
    var collapsed=isPast&&S._collapsedDates&&S._collapsedDates[d];
    return'<div class="tasks-group" id="tg-'+d+'">'+
      '<div class="section-label" style="margin-bottom:8px;margin-top:'+(dates.indexOf(d)===0?'0':'14px')+'" onclick="toggleDateGroup(\''+d+'\')">'+
        '<span style="font-size:10px;margin-right:2px;transition:transform .2s;display:inline-block" id="tga-'+d+'">'+(collapsed?'▶':'▼')+'</span>'+
        label+hint+
      '</div>'+
      '<div id="tgc-'+d+'" '+(collapsed?'style="display:none"':'')+'>'+sorted.map(taskHtml).join('')+'</div>'+
    '</div>';
  }).join('');
  el.innerHTML=html;
}
function toggleDateGroup(d){
  if(!S._collapsedDates)S._collapsedDates={};
  S._collapsedDates[d]=!S._collapsedDates[d];
  var c=eid('tgc-'+d),a=eid('tga-'+d);
  if(c)c.style.display=S._collapsedDates[d]?'none':'';
  if(a)a.textContent=S._collapsedDates[d]?'▶':'▼';
}
function initCollapsedDates(){
  if(!S._collapsedDates)S._collapsedDates={};
  var today=todayStr();
  var past=[...new Set(S.tasks.map(function(t){return t.date;}).filter(function(d){return d&&d<today;}))];
  past.forEach(function(d){if(S._collapsedDates[d]===undefined)S._collapsedDates[d]=true;});
}

