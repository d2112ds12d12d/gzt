function renderCompare(){
  const canvas=document.getElementById('chartCompare'),tableEl=document.getElementById('compareTable');
  if(compareChart){compareChart.destroy();compareChart=null;}
  const weeks=getRecentWeeks(4);
  const wLabels=weeks.map(w=>{const e=new Date(w);e.setDate(e.getDate()+6);return `${w.slice(5).replace('-','/')}~${e.toISOString().slice(5,10).replace('-','/')}`;});
  const sf=document.getElementById('compareSiteSel').value;
  let datasets=[],tableRows=[];
  const buildRates=(qaD,diff5D,sumD,diff4D,isPhone)=>weeks.map(w=>{
