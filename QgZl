      tableRows.push({label:t.label,rates});
    });
  } else if(compareView==='five_dw'){
    const cats=['笔记本','平板','手表','耳机','相机'];
    const colors=['#2563eb','#f59e0b','#ec4899','#10b981','#6366f1'];
    cats.forEach((cat,ci)=>{
      const sumD=DATA.sum.filter(r=>r.siteType==='质检中心'&&r.cat===cat&&(sf==='__ALL__'||r.site===sf));
      const diff4D=dedup(DATA.diff4.filter(r=>r.siteType==='质检中心'&&r.cat===cat&&r.subjobj==='客观问题'&&r.judgedType==='执行问题'&&(sf==='__ALL__'||r.site===sf)),r=>r.date+'|'+r.code);
      const rates=buildRates([],[],sumD,diff4D,false);
      datasets.push({label:cat,data:rates,borderColor:colors[ci],backgroundColor:'transparent',tension:.4,pointRadius:4,borderWidth:2,spanGaps:true});
      tableRows.push({label:cat,rates});
    });
  } else {
    const items=[{cat:'手机',isPhone:true},{cat:'笔记本',isPhone:false}];
    const colors=['#2563eb','#f59e0b'];
    items.forEach((item,ci)=>{
      let rates;
      if(item.isPhone){ const qaD=DATA.qa.filter(r=>r.siteType==='中心仓'&&r.cat==='手机'&&(sf==='__ALL__'||r.site===sf)); const diff5D=dedup(DATA.diff5.filter(r=>r.siteType==='中心仓'&&r.cat==='手机'&&r.strategy==='大盘评估/站点'&&r.subjobj==='客观问题'&&r.judgedType==='执行问题'&&(sf==='__ALL__'||r.site===sf)),r=>r.date+'|'+r.code); rates=buildRates(qaD,diff5D,[],[],true); }
      else{ const sumD=DATA.sum.filter(r=>r.siteType==='中心仓'&&r.cat===item.cat&&(sf==='__ALL__'||r.site===sf)); const diff4D=dedup(DATA.diff4.filter(r=>r.siteType==='中心仓'&&r.cat===item.cat&&r.subjobj==='客观问题'&&r.judgedType==='执行问题'&&(sf==='__ALL__'||r.site===sf)),r=>r.date+'|'+r.code); rates=buildRates([],[],sumD,diff4D,false); }
      datasets.push({label:item.cat,data:rates,borderColor:colors[ci],backgroundColor:'transparent',tension:.4,pointRadius:4,borderWidth:2,spanGaps:true});
      tableRows.push({label:item.cat,rates});
    });
