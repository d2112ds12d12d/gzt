function dedup(arr,keyFn){ const seen=new Set(); return arr.filter(r=>{const k=keyFn(r);if(seen.has(k))return false;seen.add(k);return true;}); }
function sum(arr,f){ return arr.reduce((s,r)=>s+(parseFloat(r[f])||0),0); }
function getWeekLabel(date){ const d=new Date(date),day=d.getDay()||7; d.setDate(d.getDate()-day+1); return d.toISOString().slice(0,10); }
function getRecentWeeks(n){ const today=new Date(),day=today.getDay()||7; const mon=new Date(today); mon.setDate(today.getDate()-day+1); const wks=[]; for(let i=n-1;i>=0;i--){const d=new Date(mon);d.setDate(mon.getDate()-i*7);wks.push(d.toISOString().slice(0,10));} return wks; }
function renderPageBtns(cid,cur,total,fn,pp){ const btns=document.getElementById(cid); if(pp>=999999){btns.innerHTML='';return;} let html=`<button class="page-btn" onclick="${fn.name}(${cur-1})" ${cur<=1?'disabled':''}>‹</button>`; const range=[]; for(let i=1;i<=total;i++){if(i===1||i===total||Math.abs(i-cur)<=1)range.push(i);} let prev=null; range.forEach(i=>{if(prev&&i-prev>1)html+=`<span style="font-size:11px;color:#94a3b8;padding:0 2px;">…</span>`; html+=`<button class="page-btn${i===cur?' active':''}" onclick="${fn.name}(${i})">${i}</button>`; prev=i;}); html+=`<button class="page-btn" onclick="${fn.name}(${cur+1})" ${cur>=total?'disabled':''}>›</button>`; btns.innerHTML=html; }

// ============================================================
// 页面切换 / Toast
// ============================================================
function switchPage(page,el){ document.querySelectorAll('.page').forEach(p=>p.classList.remove('active')); document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active')); const pg=document.getElementById('page-'+page); if(pg)pg.classList.add('active'); if(el&&!el.classList.contains('disabled'))el.classList.add('active'); }
function showToast(msg){ const t=document.getElementById('toast'); t.textContent=msg; t.style.display='block'; clearTimeout(t._t); t._t=setTimeout(()=>t.style.display='none',3000); }

