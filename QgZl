let compareView='phone_dw', compareChart=null;
function setCompareView(el,v){ document.querySelectorAll('.view-tab').forEach(t=>t.classList.remove('active')); el.classList.add('active'); compareView=v; buildCompareSiteOptions(); renderCompare(); }
function buildCompareSiteOptions(){
  const sel=document.getElementById('compareSiteSel');
  let sites=[];
  if(compareView==='phone_dw') sites=[...new Set(DATA.qa.filter(r=>r.siteType==='质检中心').map(r=>r.site))];
  else if(compareView==='five_dw') sites=[...new Set(DATA.sum.filter(r=>r.siteType==='质检中心').map(r=>r.site))];
  else sites=[...new Set([...DATA.qa.filter(r=>r.siteType==='中心仓').map(r=>r.site),...DATA.sum.filter(r=>r.siteType==='中心仓').map(r=>r.site)])];
  sites.sort(); const cur=sel.value;
  sel.innerHTML='<option value="__ALL__">全部站点</option>'+sites.map(s=>`<option ${s===cur?'selected':''}>${s}</option>`).join('');
