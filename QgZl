function openColDrop(e,colKey){
  e.stopPropagation();
  const drop=document.getElementById('colDropdown');
  const th=e.currentTarget.closest('th');
  const rect=th.getBoundingClientRect();
  // 定位
  drop.style.left=rect.left+'px';
  drop.style.top=(rect.bottom+window.scrollY)+'px';
  activeColKey=colKey;
  // 收集该列所有唯一值（从全局筛选后的数据）
  const vals=[...new Set(allDetailRows.map(r=>String(r[colKey]||'')).filter(v=>v!==''))].sort();
  const sel=COL_FILTERS[colKey]||new Set();
  document.getElementById('colSearchInput').value='';
  renderColOpts(vals,sel);
  drop.classList.add('open');
}
function closeColDrop(){ document.getElementById('colDropdown').classList.remove('open'); activeColKey=null; }
function filterColOpts(){
  const q=document.getElementById('colSearchInput').value.trim().toLowerCase();
  const vals=[...new Set(allDetailRows.map(r=>String(r[activeColKey]||'')).filter(v=>v!==''))].sort().filter(v=>!q||v.toLowerCase().includes(q));
  renderColOpts(vals,COL_FILTERS[activeColKey]||new Set());
}
function renderColOpts(vals,sel){
  const allChecked=sel.size===0;
  document.getElementById('colOptList').innerHTML=
    `<div class="col-opt opt-all" onclick="toggleAllColOpts()"><input type="checkbox" ${allChecked?'checked':''} id="colAllCb"> 全部</div>`
    +vals.map(v=>`<div class="col-opt"><input type="checkbox" data-val="${v}" ${allChecked||sel.has(v)?'checked':''} onchange="toggleColOpt(this,'${v}')"> ${v||'(空)'}</div>`).join('');
}
function toggleAllColOpts(){ if(COL_FILTERS[activeColKey])COL_FILTERS[activeColKey]=new Set(); renderColOpts([...new Set(allDetailRows.map(r=>String(r[activeColKey]||'')).filter(v=>v!==''))].sort(),new Set()); }
function selectAllColOpts(){ COL_FILTERS[activeColKey]=new Set(); const vals=[...new Set(allDetailRows.map(r=>String(r[activeColKey]||'')).filter(v=>v!==''))].sort(); renderColOpts(vals,new Set()); }
function clearColOpts(){ const vals=[...new Set(allDetailRows.map(r=>String(r[activeColKey]||'')).filter(v=>v!==''))].sort(); const s=new Set(vals); COL_FILTERS[activeColKey]=s; renderColOpts(vals,s); }
function toggleColOpt(cb,val){
  if(!COL_FILTERS[activeColKey])COL_FILTERS[activeColKey]=new Set();
  const s=COL_FILTERS[activeColKey];
  if(s.size===0){ const vals=[...new Set(allDetailRows.map(r=>String(r[activeColKey]||'')).filter(v=>v!==''))]; vals.forEach(v=>s.add(v)); }
  if(cb.checked)s.add(val); else s.delete(val);
  if(s.size===[...new Set(allDetailRows.map(r=>String(r[activeColKey]||'')).filter(v=>v!==''))].length)COL_FILTERS[activeColKey]=new Set();
  const q=document.getElementById('colSearchInput').value.trim().toLowerCase();
  const allVals=[...new Set(allDetailRows.map(r=>String(r[activeColKey]||'')).filter(v=>v!==''))].sort().filter(v=>!q||v.toLowerCase().includes(q));
  renderColOpts(allVals,COL_FILTERS[activeColKey]||new Set());
}
function applyColFilter(){ closeColDrop(); applyColFiltersToDetail(); }

