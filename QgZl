// 推送单个数据文件到GitHub
async function pushToGitHub(tableType){
  const token=getEffectiveToken();
  const fname=GH_FILES[tableType];
  const content={rows:DATA[tableType],updated:new Date().toISOString()};
  const b64=btoa(unescape(encodeURIComponent(JSON.stringify(content,null,0))));
  // 先获取已有文件SHA（覆盖需要SHA）
  let sha='';
  try{
    const r=await fetch(ghUrl(fname),{headers:{Authorization:'token '+token}});
    if(r.ok){ const j=await r.json(); sha=j.sha||''; }
  }catch(e){}
  // 推送
  const body={message:`Update ${fname} via dashboard`,content:b64};
  if(sha) body.sha=sha;
  const res=await fetch(ghUrl(fname),{method:'PUT',headers:{Authorization:'token '+token,'Content-Type':'application/json'},body:JSON.stringify(body)});
  return res.ok;
}

