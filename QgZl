    if(isPhone){ checks=sum(qaD.filter(r=>getWeekLabel(r.date)===w),'checks'); diff=diff5D.filter(r=>getWeekLabel(r.date)===w).length; }
    else{ checks=sum(sumD.filter(r=>getWeekLabel(r.date)===w),'checks'); diff=diff4D.filter(r=>getWeekLabel(r.date)===w).length; }
    return checks>0?+(diff/checks*100).toFixed(2):null;
  });
