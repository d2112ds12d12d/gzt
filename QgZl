function renderRank(){
  const el=document.getElementById('rankList');
  const siteMap={};
  const qaF=filterRows(DATA.qa); const diff5F=dedup(filterRows(DATA.diff5).filter(r=>r.strategy==='大盘评估/站点'&&r.subjobj==='客观问题'&&r.judgedType==='执行问题'),r=>r.date+'|'+r.code);
  const sumF=filterRows(DATA.sum); const diff4F=dedup(filterRows(DATA.diff4).filter(r=>r.subjobj==='客观问题'&&r.judgedType==='执行问题'),r=>r.date+'|'+r.code);
  const addSite=(site,checks,diff)=>{if(!siteMap[site])siteMap[site]={site,checks:0,diff:0};siteMap[site].checks+=checks;siteMap[site].diff+=diff;};
  qaF.forEach(r=>{ if(FILTER.cat==='全部'||r.cat===FILTER.cat)addSite(r.site,r.checks,0); });
  diff5F.forEach(r=>{ if(FILTER.cat==='全部'||r.cat===FILTER.cat)addSite(r.site,0,1); });
  sumF.forEach(r=>{ if(FILTER.cat==='全部'||r.cat===FILTER.cat)addSite(r.site,r.checks,0); });
  diff4F.forEach(r=>{ if(FILTER.cat==='全部'||r.cat===FILTER.cat)addSite(r.site,0,1); });
  const ranked=Object.values(siteMap).filter(s=>s.checks>0).map(s=>({...s,rate:s.diff/s.checks*100})).sort((a,b)=>b.rate-a.rate).slice(0,15);
  if(!ranked.length){el.innerHTML='<div class="empty-state"><div class="empty-text">暂无数据</div></div>';return;}
  const maxR=ranked[0].rate||1;
  el.innerHTML=ranked.map((r,i)=>{
    const pct=(r.rate/maxR*100).toFixed(0);
    const color=r.rate>5?'#dc2626':r.rate>2?'#f59e0b':'#22c55e';
    // 警示图标：越高越危险
    let badge,badgeCls;
    if(i===0){badge='⚠';badgeCls='rank-danger';}
    else if(i===1){badge='▲';badgeCls='rank-warn';}
    else if(i===2){badge='▲';badgeCls='rank-warn';}
    else{badge=String(i+1);badgeCls='rank-normal';}
    return `<div class="rank-item" style="animation-delay:${i*.03}s">
      <div class="rank-badge ${badgeCls}">${badge}</div>
      <div class="rank-name" title="${r.site}">${r.site}</div>
      <div class="rank-bar-wrap"><div class="rank-bar" style="width:${pct}%;background:${color}"></div></div>
