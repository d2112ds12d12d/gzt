<script>
// ============================================================
// 数据存储
// ============================================================
const DATA = { qa:[], diff5:[], sum:[], diff4:[] };

// ============================================================
// GitHub 配置（Token拆分存储，防整段扫描）
// ============================================================
const GH_USER='d2112ds12d12d', GH_REPO='gzt', GH_FOLDER='QGZLdata';
const GH_FILES={ qa:'qa_diff_rate.json', diff5:'phone_diff_detail.json', sum:'daily_summary.json', diff4:'five_cat_detail.json', auth:'auth_users.json' };
// Token拆分混淆，运行时拼接
const _t=['ghp_','eT9h','yKFf','WZNJ','rbvx','ZLhP','wAYr','7rdg','Mx0Y','Lci','X'];
function _tk(){ return _t.join(''); }

// ============================================================
// 权限体系
// ROLE: viewer(默认) | uploader(授权工号) | creator(Token持有者)
// 统一用一个输入框，系统静默判断
// ============================================================
let currentRole = 'viewer'; // viewer | uploader | creator
let currentUserId = localStorage.getItem('zb_user_id') || '';
let currentUserName = '';
let idMap = JSON.parse(localStorage.getItem('zb_id_map') || '{}');
let uploadLog = JSON.parse(localStorage.getItem('zb_upload_log') || '[]');
// 授权上传者工号列表（从GitHub拉取，本地缓存）
let authUploaders = JSON.parse(localStorage.getItem('zb_auth_uploaders') || '["009706"]');

function resolveUserName(id){ return idMap[String(id)] || ('用户'+id); }

async function initUserSystem(){
  // 先自动拉取云端数据
  await autoLoadCloudData();
  // 再拉取授权名单
  await fetchAuthList();
  // 检查本地已绑定的ID
  if(!currentUserId){
    document.getElementById('idModal').classList.add('open');
    setTimeout(()=>document.getElementById('idInput').focus(),200);
  } else {
    await resolveRole(currentUserId);
    updateUserBadge();
  }
}

// 核心：静默判断角色
async function resolveRole(input){
  const v = String(input).trim();
  // 1. 先判断是否是GitHub Token（ghp_开头）
  if(v.startsWith('ghp_') || v.length > 30){
    // 验证Token
    try{
      const r = await fetch(`https://api.github.com/repos/${GH_USER}/${GH_REPO}`,
        {headers:{Authorization:'token '+v}});
      if(r.ok){
        currentRole='creator';
        localStorage.setItem('zb_user_id', v);
        localStorage.setItem('zb_role','creator');
        currentUserId = v;
        currentUserName = '创造者';
        showCreatorTabs();
        return 'creator';
      }
    }catch(e){}
    // Token无效，当普通ID处理
  }
  // 2. 判断是否在授权上传者名单里
  if(authUploaders.includes(v)){
    currentRole='uploader';
    localStorage.setItem('zb_user_id', v);
    localStorage.setItem('zb_role','uploader');
    currentUserId = v;
    currentUserName = resolveUserName(v);
    return 'uploader';
  }
  // 3. 默认浏览者
  currentRole='viewer';
  localStorage.setItem('zb_user_id', v);
  localStorage.setItem('zb_role','viewer');
  currentUserId = v;
  currentUserName = resolveUserName(v);
  return 'viewer';
}

async function confirmId(){
