// 文件上传 & 解析（智能按日期合并）
// ============================================================
async function handleMultiUpload(input){
  const files=Array.from(input.files); if(!files.length)return;
  showToast('正在解析…');
  for(const file of files){
    try{
      const buf=await file.arrayBuffer();
      const wb=XLSX.read(buf,{type:'array',cellDates:true});
      const ws=wb.Sheets[wb.SheetNames[0]];
      const rows=XLSX.utils.sheet_to_json(ws,{raw:false,defval:''});
      if(!rows.length){showToast('⚠️ 文件无数据: '+file.name);continue;}
      const fr=rows[0];
      let tableType='',tableName='',parsed=[];
      if('大盘抽检设备数量' in fr){
        tableType='qa'; tableName='QA差异率_站点维度';
        parsed=rows.map(r=>({date:nd(r['抽检日期']),site:(r['站点名称']||'').trim(),siteType:getSiteType(r['站点名称']),cat:CAT_MAP[r['品类名称']]||r['品类名称']||'',checks:parseFloat(r['大盘抽检设备数量'])||0}));
        DATA.qa=smartMerge(DATA.qa,parsed); setChipLoaded('chip-qa',true);
      } else if('主客观问题分类' in fr&&'策略类别' in fr){
        tableType='diff5'; tableName='手机差异明细(表5)';
        parsed=rows.map(r=>({date:nd(r['日期']),code:(r['质检码']||'').trim(),site:(r['站点名称']||'').trim(),siteType:getSiteType(r['站点名称']),cat:CAT_MAP[r['品类名称']]||r['品类名称']||'',strategy:(r['策略类别']||'').trim(),level1:r['一级项名称']||'',level2:r['二级项名称']||'',level3_orig:r['原三级项名称']||'',level3_new:r['新三级项名称']||'',subjobj:(r['主客观问题分类']||'').trim(),issueType:(r['问题类型']||'').trim(),judgedType:(r['抽检判定的问题类型']||'').trim(),inspector:extractCN(r['原操作人名称']||''),qaInspector:extractCN(r['新操作人名称']||'')}));
        DATA.diff5=smartMerge(DATA.diff5,parsed); setChipLoaded('chip-diff5',true);
      } else if('抽检总量' in fr&&'品类' in fr&&!('质检码' in fr)){
        tableType='sum'; tableName='日汇总';
        parsed=rows.map(r=>({date:nd(r['日期']),site:(r['站点']||'').trim(),siteType:getSiteType(r['站点']),cat:CAT_MAP[r['品类']]||r['品类']||'',checks:parseFloat(r['抽检总量'])||0,objDiff:parseFloat(r['客观差异数量'])||0}));
        DATA.sum=smartMerge(DATA.sum,parsed); setChipLoaded('chip-sum',true);
      } else if('主客观分类' in fr&&'问题分类' in fr){
        tableType='diff4'; tableName='五品类差异明细(表4)';
        parsed=rows.map(r=>({date:nd(r['抽检时间']),code:(r['质检码']||'').trim(),site:(r['站点']||'').trim(),siteType:getSiteType(r['站点']),cat:CAT_MAP[r['品类']]||r['品类']||'',level1:r['一级项']||'',level2:r['二级项']||'',level3_orig:r['原三级项']||'',level3_new:r['新三级项']||'',subjobj:(r['主客观分类']||'').trim(),issueType:(r['质检项类型']||'').trim(),judgedType:(r['问题分类']||'').trim(),inspector:extractCN(r['质检师']||''),qaInspector:extractCN(r['QA']||'')}));
        DATA.diff4=smartMerge(DATA.diff4,parsed); setChipLoaded('chip-diff4',true);
      } else {showToast('⚠️ 无法识别: '+file.name);continue;}
      const arr=DATA[tableType];
      const dates=arr.map(r=>r.date).filter(Boolean).sort();
      addLog({userId:currentUserId,userName:resolveUserName(currentUserId),tableType,tableName,dateMin:dates[0]||'—',dateMax:dates[dates.length-1]||'—',rows:arr.length});
      showToast('✓ '+tableName+' 已加载');
    }catch(e){showToast('✗ 解析失败: '+file.name);console.error(e);}
  }
  document.getElementById('lastUpdateTime').textContent=new Date().toLocaleString('zh-CN',{month:'2-digit',day:'2-digit',hour:'2-digit',minute:'2-digit'});
  input.value='';
  buildSiteOptions();
  applyFilter();
  // 上传者/创造者：推送到GitHub
  if(currentRole==='uploader'||currentRole==='creator'){
    showToast('⏳ 正在同步到云端…');
    try{
      const pushKeys=['qa','diff5','sum','diff4'].filter(k=>DATA[k].length>0);
      let ok=0;
      for(const key of pushKeys){ const s=await pushToGitHub(key); if(s)ok++; }
      showToast(ok>0?`✓ 已同步 ${ok} 个文件到云端`:'⚠️ 同步失败，请检查网络');
    }catch(e){ showToast('✗ 同步出错: '+e.message); console.error(e); }
  }
}

function smartMerge(existing,incoming){
  if(!existing.length)return incoming;
  const inDates=new Set(incoming.map(r=>r.date).filter(Boolean));
  return [...existing.filter(r=>!inDates.has(r.date)),...incoming];
}
function setChipLoaded(id,ok){ const el=document.getElementById(id); if(el){el.classList.toggle('loaded',ok);el.classList.remove('error');} }
function nd(v){ if(!v)return ''; const s=String(v).trim(); if(/^\d{4}-\d{2}-\d{2}/.test(s))return s.slice(0,10); const n=parseFloat(s); if(!isNaN(n)&&n>40000){const d=new Date((n-25569)*86400*1000);return d.toISOString().slice(0,10);} return s.slice(0,10); }
function extractCN(str){ if(!str)return ''; const m=str.match(/[\u4e00-\u9fa5]+/g); if(m)return m.join(''); const m2=str.match(/[（(]([^）)]+)[）)]/); if(m2)return m2[1]; return str.trim(); }

// ============================================================
// 工具
