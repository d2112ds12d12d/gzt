function filterRows(rows,dateField='date'){
  return rows.filter(r=>{
    const d=r[dateField]||'';
    const dateOk=(!FILTER.dateFrom||d>=FILTER.dateFrom)&&(!FILTER.dateTo||d<=FILTER.dateTo);
    const siteTypeOk=FILTER.siteType==='全部'||r.siteType===FILTER.siteType;
    const siteOk=FILTER.sites.length===0||FILTER.sites.includes(r.site);
    const catOk=FILTER.cat==='全部'||r.cat===FILTER.cat;
    // 大仓子类型
    let dwOk=true;
    if(FILTER.siteType==='质检中心'&&FILTER.cat==='手机'&&FILTER.dwSub!=='全部'){
      dwOk=getDwSub(r.site)===FILTER.dwSub;
    }
    return dateOk&&siteTypeOk&&siteOk&&catOk&&dwOk;
  });
}

