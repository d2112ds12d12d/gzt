  compareChart=new Chart(canvas,{type:'line',data:{labels:wLabels,datasets},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'bottom',labels:{boxWidth:10,padding:10,font:{size:11}}}},scales:{y:{grid:{color:'rgba(200,210,230,0.4)'},ticks:{callback:v=>v+'%',font:{size:10}},beginAtZero:true},x:{grid:{display:false},ticks:{font:{size:10}}}}}});
  tableEl.innerHTML=tableRows.length?`<table class="trend-table"><thead><tr><th>品类/类型</th>${wLabels.map(w=>`<th>${w}</th>`).join('')}<th>环比</th></tr></thead><tbody>${tableRows.map(row=>{
    const lt=row.rates.filter(r=>r!==null);
    let ratio='—',rCls='ratio-flat';
    if(lt.length>=2&&lt[lt.length-2]!==0){const rv=((lt[lt.length-1]-lt[lt.length-2])/lt[lt.length-2]*100).toFixed(2);ratio=(rv>0?'+':'')+rv+'%';rCls=rv>0?'ratio-up':rv<0?'ratio-down':'ratio-flat';}
    return `<tr><td>${row.label}</td>${row.rates.map(v=>`<td>${v!==null?v+'%':'—'}</td>`).join('')}<td class="${rCls}">${ratio}</td></tr>`;
  }).join('')}</tbody></table>`:'';
