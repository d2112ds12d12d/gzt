<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>培训部数据看板</title>
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:-apple-system,'PingFang SC','Microsoft YaHei',sans-serif;background:linear-gradient(135deg,#e8edf5 0%,#dce4f0 50%,#e4e8f4 100%);color:#1e293b;display:flex;height:100vh;overflow:hidden;}

/* SIDEBAR */
#sidebar{width:210px;min-width:210px;background:rgba(255,255,255,0.55);backdrop-filter:blur(24px) saturate(200%);border-right:1px solid rgba(255,255,255,0.75);display:flex;flex-direction:column;overflow:hidden;box-shadow:2px 0 16px rgba(100,120,180,0.08);}
.sidebar-logo{padding:20px 16px 14px;border-bottom:1px solid rgba(200,210,230,0.5);}
.sidebar-logo .brand{font-size:18px;font-weight:900;color:#2563eb;position:relative;overflow:hidden;cursor:default;}
.sidebar-logo .brand::after{content:'';position:absolute;top:0;left:-100%;width:50%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.6),transparent);animation:shimmer 3s ease-in-out infinite;}
@keyframes shimmer{0%{left:-100%}100%{left:150%}}
.sidebar-logo .sub{font-size:10px;color:#94a3b8;margin-top:3px;}
.nav-section{padding:14px 12px 5px;font-size:10px;color:#94a3b8;letter-spacing:1.5px;font-weight:600;}
.nav-item{display:flex;align-items:center;gap:9px;padding:9px 16px;cursor:pointer;font-size:13px;color:#64748b;border-left:3px solid transparent;transition:all .18s;position:relative;overflow:hidden;}
.nav-item:hover{background:rgba(37,99,235,0.07);color:#1e40af;transform:translateX(3px);}
.nav-item.active{background:rgba(37,99,235,0.10);color:#2563eb;border-left-color:#2563eb;font-weight:600;transform:translateX(3px);}
.nav-item.disabled{opacity:0.35;cursor:not-allowed;}
.nav-item.disabled:hover{transform:none;background:none;color:#64748b;}
.nav-icon{width:16px;height:16px;flex-shrink:0;transition:transform .2s;}
.nav-item:hover .nav-icon,.nav-item.active .nav-icon{transform:scale(1.15);}
.sidebar-footer{margin-top:auto;padding:12px 14px 14px;border-top:1px solid rgba(200,210,230,0.5);}
.user-badge{display:flex;align-items:center;gap:6px;padding:5px 10px;border-radius:10px;background:rgba(37,99,235,0.07);border:1px solid rgba(37,99,235,0.15);cursor:pointer;transition:all .15s;margin-bottom:8px;}
.user-badge:hover{background:rgba(37,99,235,0.12);}
.user-avatar{width:20px;height:20px;border-radius:50%;background:#2563eb;color:#fff;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;flex-shrink:0;}
.user-name{font-size:11px;font-weight:600;color:#2563eb;}
.user-id-lbl{font-size:10px;color:#94a3b8;}
.upload-status{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:8px;}
.ds-chip{font-size:10px;padding:2px 8px;border-radius:10px;background:rgba(241,245,249,0.8);border:1px solid rgba(200,210,230,0.6);color:#64748b;}
.ds-chip.loaded{background:rgba(5,150,105,0.08);border-color:rgba(5,150,105,0.3);color:#059669;}
.ver-row{display:flex;align-items:center;justify-content:space-between;}
.ver{font-size:10px;color:#94a3b8;}

/* MAIN */
#main{flex:1;display:flex;flex-direction:column;overflow:hidden;}
.topbar{background:rgba(255,255,255,0.70);backdrop-filter:blur(20px);border-bottom:1px solid rgba(200,210,230,0.6);padding:0 20px;height:50px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;gap:12px;}
.topbar-title{font-size:14px;font-weight:700;color:#1e293b;white-space:nowrap;}
.marquee-wrap{flex:1;overflow:hidden;margin:0 12px;background:rgba(37,99,235,0.05);border-radius:20px;border:1px solid rgba(37,99,235,0.15);padding:0 14px;}
.marquee-inner{display:inline-block;white-space:nowrap;animation:marquee 30s linear infinite;font-size:12px;color:#2563eb;font-weight:600;}
.marquee-inner:hover{animation-play-state:paused;}
@keyframes marquee{0%{transform:translateX(100%)}100%{transform:translateX(-100%)}}
.topbar-right{display:flex;align-items:center;gap:8px;flex-shrink:0;}
.update-area{display:flex;align-items:center;gap:6px;}
.update-time{font-size:11px;color:#64748b;background:rgba(241,245,249,0.8);padding:4px 11px;border-radius:20px;border:1px solid rgba(200,210,230,0.7);white-space:nowrap;}
.update-label{color:#94a3b8;margin-right:3px;}
.log-btn{font-size:11px;padding:4px 10px;border-radius:20px;border:1px solid rgba(200,210,230,0.7);background:rgba(241,245,249,0.8);color:#64748b;cursor:pointer;transition:all .15s;white-space:nowrap;}
.log-btn:hover{border-color:#2563eb;color:#2563eb;background:rgba(37,99,235,0.06);}
.upload-btn{font-size:12px;padding:4px 14px;border-radius:20px;border:1.5px dashed rgba(37,99,235,0.5);background:rgba(37,99,235,0.06);color:#2563eb;cursor:pointer;transition:all .18s;white-space:nowrap;}
.upload-btn:hover{background:#2563eb;color:#fff;border-style:solid;}
input[type=file]{display:none;}

.content{flex:1;overflow-y:auto;padding:16px 20px;}
.content::-webkit-scrollbar{width:4px;}
.content::-webkit-scrollbar-thumb{background:rgba(148,163,184,0.4);border-radius:2px;}

/* GLASS CARD */
.card{padding:14px 16px;border-radius:12px;background:rgba(255,255,255,0.65);backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,0.9);box-shadow:0 2px 10px rgba(100,120,180,0.08);transition:transform .18s,box-shadow .18s;}
.card:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(100,120,180,0.13);}
.glass{background:rgba(255,255,255,0.62);backdrop-filter:blur(20px) saturate(180%);border:1px solid rgba(255,255,255,0.85);box-shadow:0 4px 24px rgba(100,120,180,0.10);}

/* FILTER BAR */
.filter-bar{display:flex;align-items:center;flex-wrap:wrap;gap:8px;padding:11px 16px;border-radius:12px;margin-bottom:14px;}
.filter-label{font-size:11px;color:#64748b;font-weight:600;white-space:nowrap;}
.filter-input{font-size:12px;padding:4px 9px;border-radius:7px;border:1px solid rgba(200,210,230,0.8);background:rgba(255,255,255,0.7);color:#1e293b;outline:none;font-family:inherit;}
.filter-chip{font-size:12px;padding:3px 12px;border-radius:20px;cursor:pointer;border:1px solid rgba(200,210,230,0.8);background:rgba(255,255,255,0.6);color:#64748b;transition:all .15s;white-space:nowrap;user-select:none;}
.filter-chip.active{background:#2563eb;color:#fff;border-color:#2563eb;}
.filter-chip:hover:not(.active){background:rgba(37,99,235,0.08);color:#2563eb;border-color:#2563eb;}
.filter-chip:active{transform:scale(.96);}
.filter-div{width:1px;height:14px;background:rgba(200,210,230,0.6);margin:0 2px;}

/* 站点多选下拉 */
.site-multisel-wrap{position:relative;display:inline-block;}
.site-multisel-btn{font-size:12px;padding:3px 10px;border-radius:7px;border:1px solid rgba(200,210,230,0.8);background:rgba(255,255,255,0.7);color:#1e293b;cursor:pointer;display:flex;align-items:center;gap:5px;min-width:90px;justify-content:space-between;transition:border-color .15s;}
.site-multisel-btn:hover{border-color:#2563eb;}
.site-multisel-btn.has-sel{border-color:#2563eb;background:rgba(37,99,235,0.06);color:#2563eb;}
.site-dropdown{position:absolute;top:calc(100% + 4px);left:0;min-width:180px;background:rgba(255,255,255,0.97);backdrop-filter:blur(16px);border:1px solid rgba(200,210,230,0.8);border-radius:10px;box-shadow:0 8px 24px rgba(100,120,180,0.15);z-index:100;display:none;max-height:280px;overflow:hidden;flex-direction:column;}
.site-dropdown.open{display:flex;animation:fadeUp .15s ease both;}
.site-search-box{padding:8px 10px;border-bottom:1px solid rgba(200,210,230,0.4);}
.site-search-input{width:100%;font-size:12px;padding:5px 9px;border-radius:7px;border:1px solid rgba(200,210,230,0.8);background:rgba(241,245,249,0.8);outline:none;font-family:inherit;}
.site-search-input:focus{border-color:#2563eb;}
.site-options{overflow-y:auto;flex:1;}
.site-option{display:flex;align-items:center;gap:8px;padding:7px 12px;font-size:12px;color:#334155;cursor:pointer;transition:background .1s;}
.site-option:hover{background:rgba(37,99,235,0.06);}
.site-option input[type=checkbox]{accent-color:#2563eb;width:13px;height:13px;cursor:pointer;}
.site-option.ms-all{border-bottom:1px solid rgba(200,210,230,0.4);font-weight:600;color:#2563eb;}
.site-footer{padding:6px 10px;border-top:1px solid rgba(200,210,230,0.4);display:flex;gap:6px;}
.site-footer-btn{flex:1;font-size:11px;padding:4px;border-radius:6px;border:1px solid rgba(200,210,230,0.8);background:rgba(255,255,255,0.7);color:#475569;cursor:pointer;transition:all .12s;}
.site-footer-btn:hover{background:#2563eb;color:#fff;border-color:#2563eb;}

/* 大仓子类型chips */
#dwSubChips{display:none;align-items:center;gap:6px;}
#dwSubChips.visible{display:flex;}

/* SECTION HEADER */
.section-hd{font-size:13px;font-weight:700;color:#334155;margin-bottom:10px;display:flex;align-items:center;justify-content:space-between;}
.section-hd-left{display:flex;align-items:center;gap:8px;}
.section-hd-left::before{content:'';width:3px;height:14px;background:#2563eb;border-radius:2px;display:block;}

/* OVERVIEW CARDS */
.overview-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:10px;margin-bottom:14px;}
.ov-card{border-radius:14px;padding:14px 13px;position:relative;overflow:hidden;cursor:default;transition:transform .15s,box-shadow .15s;animation:fadeUp .3s ease both;}
.ov-card:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(100,120,180,0.15);}
.ov-card:nth-child(1){animation-delay:.03s}.ov-card:nth-child(2){animation-delay:.06s}
.ov-card:nth-child(3){animation-delay:.09s}.ov-card:nth-child(4){animation-delay:.12s}
.ov-card:nth-child(5){animation-delay:.15s}.ov-card:nth-child(6){animation-delay:.18s}
.ov-cat{font-size:11px;font-weight:600;margin-bottom:6px;display:flex;align-items:center;gap:5px;}
.ov-icon{font-size:15px;}
.ov-big{font-size:20px;font-weight:800;line-height:1;margin-bottom:4px;}
.ov-row{display:flex;justify-content:space-between;align-items:flex-end;}
.ov-label{font-size:10px;opacity:.7;}
.ov-rate{font-size:14px;font-weight:700;}
.ov-sub{font-size:10px;opacity:.6;margin-top:3px;}
.ov-phone{background:linear-gradient(135deg,rgba(37,99,235,0.12),rgba(96,165,250,0.08));border:1px solid rgba(37,99,235,0.2);}
.ov-phone .ov-cat,.ov-phone .ov-rate{color:#1d4ed8;}.ov-phone .ov-big{color:#1e40af;}
.ov-laptop{background:linear-gradient(135deg,rgba(124,58,237,0.12),rgba(167,139,250,0.08));border:1px solid rgba(124,58,237,0.2);}
.ov-laptop .ov-cat,.ov-laptop .ov-rate{color:#6d28d9;}.ov-laptop .ov-big{color:#5b21b6;}
.ov-pad{background:linear-gradient(135deg,rgba(5,150,105,0.12),rgba(52,211,153,0.08));border:1px solid rgba(5,150,105,0.2);}
.ov-pad .ov-cat,.ov-pad .ov-rate{color:#047857;}.ov-pad .ov-big{color:#065f46;}
.ov-earphone{background:linear-gradient(135deg,rgba(217,119,6,0.12),rgba(251,191,36,0.08));border:1px solid rgba(217,119,6,0.2);}
.ov-earphone .ov-cat,.ov-earphone .ov-rate{color:#b45309;}.ov-earphone .ov-big{color:#92400e;}
.ov-watch{background:linear-gradient(135deg,rgba(236,72,153,0.10),rgba(251,207,232,0.08));border:1px solid rgba(236,72,153,0.2);}
.ov-watch .ov-cat,.ov-watch .ov-rate{color:#be185d;}.ov-watch .ov-big{color:#9d174d;}
.ov-camera{background:linear-gradient(135deg,rgba(100,116,139,0.10),rgba(148,163,184,0.06));border:1px solid rgba(100,116,139,0.15);}
.ov-camera .ov-cat,.ov-camera .ov-rate{color:#475569;}.ov-camera .ov-big{color:#334155;}
.rate-bad{color:#dc2626!important;}.rate-warn{color:#d97706!important;}.rate-ok{color:#059669!important;}

/* RANK */
.rank-card{border-radius:12px;background:rgba(255,255,255,0.65);backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,0.9);box-shadow:0 2px 10px rgba(100,120,180,0.08);padding:14px 16px;margin-bottom:14px;}
.rank-item{display:flex;align-items:center;gap:7px;margin-bottom:7px;}
.rank-badge{width:22px;height:22px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;flex-shrink:0;}
.rank-danger{background:rgba(220,38,38,0.12);color:#dc2626;}
.rank-warn{background:rgba(217,119,6,0.12);color:#d97706;}
.rank-normal{background:rgba(100,116,139,0.10);color:#475569;}
.rank-name{font-size:12px;color:#334155;flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.rank-bar-wrap{width:130px;background:rgba(200,210,230,0.35);border-radius:3px;height:7px;overflow:hidden;flex-shrink:0;}
.rank-bar{height:100%;border-radius:3px;transition:width .6s cubic-bezier(.4,0,.2,1);}
.rank-val{font-size:12px;font-weight:700;min-width:44px;text-align:right;}
.chart-title{font-size:12px;color:#64748b;margin-bottom:10px;font-weight:500;}
.chart-wrap{position:relative;height:200px;}

/* DETAIL CHARTS ROW */
.detail-charts-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px;}

/* TABLE */
.table-wrap{border-radius:12px;overflow:hidden;background:rgba(255,255,255,0.65);backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,0.9);box-shadow:0 2px 10px rgba(100,120,180,0.08);margin-bottom:16px;}
.table-toolbar{display:flex;align-items:center;justify-content:space-between;padding:9px 14px 7px;flex-wrap:wrap;gap:7px;}
.table-scroll{overflow-x:auto;}
table{width:100%;border-collapse:collapse;font-size:11.5px;}
thead th{background:rgba(241,245,249,0.92);color:#475569;font-weight:600;padding:0;border-bottom:1px solid rgba(200,210,230,0.5);text-align:left;white-space:nowrap;position:sticky;top:0;z-index:2;}
.th-inner{display:flex;align-items:center;justify-content:space-between;padding:8px 10px;gap:4px;cursor:pointer;user-select:none;}
.th-inner:hover{background:rgba(37,99,235,0.05);}
.th-filter-icon{font-size:10px;color:#94a3b8;flex-shrink:0;transition:color .15s;}
.th-inner:hover .th-filter-icon{color:#2563eb;}
.th-filter-icon.active{color:#2563eb;}
tbody td{padding:7px 10px;border-bottom:1px solid rgba(200,210,230,0.3);color:#334155;white-space:nowrap;}
tbody tr:last-child td{border-bottom:none;}
tbody tr:hover td{background:rgba(37,99,235,0.04);}
.badge{display:inline-block;padding:1px 7px;border-radius:4px;font-size:10px;font-weight:600;}
.badge-obj{background:rgba(220,38,38,0.1);color:#dc2626;}
.badge-subj{background:rgba(37,99,235,0.1);color:#2563eb;}
.badge-exec{background:rgba(5,150,105,0.1);color:#059669;}
.badge-other{background:rgba(100,116,139,0.1);color:#475569;}
.pagination{display:flex;align-items:center;justify-content:space-between;padding:7px 14px;border-top:1px solid rgba(200,210,230,0.4);flex-wrap:wrap;gap:7px;}
.page-info{font-size:11px;color:#64748b;}
.page-btns{display:flex;gap:4px;align-items:center;}
.page-btn{font-size:11px;padding:3px 8px;border-radius:5px;border:1px solid rgba(200,210,230,0.8);background:rgba(255,255,255,0.7);color:#475569;cursor:pointer;transition:all .15s;}
.page-btn:hover:not(:disabled){background:#2563eb;color:#fff;border-color:#2563eb;}
.page-btn:disabled{opacity:.4;cursor:default;}
.page-btn.active{background:#2563eb;color:#fff;border-color:#2563eb;}
.per-page-sel{font-size:11px;padding:3px 7px;border-radius:6px;border:1px solid rgba(200,210,230,0.8);background:rgba(255,255,255,0.7);color:#475569;outline:none;}

/* 列头筛选下拉 */
.col-dropdown{position:absolute;top:100%;left:0;min-width:180px;background:rgba(255,255,255,0.98);backdrop-filter:blur(16px);border:1px solid rgba(200,210,230,0.8);border-radius:10px;box-shadow:0 8px 24px rgba(100,120,180,0.18);z-index:200;display:none;flex-direction:column;max-height:260px;}
.col-dropdown.open{display:flex;animation:fadeUp .14s ease both;}
.col-search{padding:8px 10px;border-bottom:1px solid rgba(200,210,230,0.35);}
.col-search input{width:100%;font-size:12px;padding:5px 9px;border-radius:7px;border:1px solid rgba(200,210,230,0.8);background:rgba(241,245,249,0.8);outline:none;font-family:inherit;}
.col-search input:focus{border-color:#2563eb;}
.col-opts{overflow-y:auto;flex:1;}
.col-opt{display:flex;align-items:center;gap:8px;padding:6px 12px;font-size:12px;color:#334155;cursor:pointer;transition:background .1s;}
.col-opt:hover{background:rgba(37,99,235,0.06);}
.col-opt input[type=checkbox]{accent-color:#2563eb;cursor:pointer;}
.col-opt.opt-all{border-bottom:1px solid rgba(200,210,230,0.4);font-weight:600;color:#2563eb;}
.col-ft{padding:6px 10px;border-top:1px solid rgba(200,210,230,0.35);display:flex;gap:6px;}
.col-ft button{flex:1;font-size:11px;padding:4px;border-radius:6px;border:1px solid rgba(200,210,230,0.8);background:rgba(255,255,255,0.7);color:#475569;cursor:pointer;}
.col-ft button:hover{background:#2563eb;color:#fff;border-color:#2563eb;}

/* COMPARE SECTION */
.view-tabs{display:flex;gap:4px;margin-bottom:10px;}
.view-tab{padding:5px 14px;font-size:12px;border-radius:20px;border:1px solid rgba(200,210,230,0.8);background:rgba(255,255,255,0.6);color:#64748b;cursor:pointer;transition:all .15s;}
.view-tab.active{background:#2563eb;color:#fff;border-color:#2563eb;}
.site-sel{font-size:12px;padding:4px 10px;border-radius:7px;border:1px solid rgba(200,210,230,0.8);background:rgba(255,255,255,0.7);color:#1e293b;outline:none;font-family:inherit;}
.trend-table{width:100%;border-collapse:collapse;font-size:12px;margin-top:12px;}
.trend-table th{background:rgba(241,245,249,0.85);color:#475569;font-weight:600;padding:7px 12px;border-bottom:1px solid rgba(200,210,230,0.5);text-align:center;}
.trend-table th:first-child{text-align:left;}
.trend-table td{padding:6px 12px;border-bottom:1px solid rgba(200,210,230,0.3);text-align:center;}
.trend-table td:first-child{text-align:left;font-weight:600;}
.trend-table tr:last-child td{border-bottom:none;}
.ratio-up{color:#dc2626;font-weight:600;}.ratio-down{color:#059669;font-weight:600;}.ratio-flat{color:#94a3b8;}

/* ANIM */
@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
.page{display:none;}.page.active{display:block;animation:fadeUp .22s ease both;}

/* TOAST */
#toast{position:fixed;bottom:20px;right:20px;background:rgba(255,255,255,0.95);backdrop-filter:blur(16px);border:1px solid rgba(200,210,230,0.8);color:#1e293b;padding:9px 16px;border-radius:10px;font-size:13px;display:none;z-index:999;box-shadow:0 4px 20px rgba(100,120,180,0.15);}

/* MODAL */
.modal-overlay{position:fixed;inset:0;background:rgba(15,23,42,0.45);backdrop-filter:blur(6px);z-index:300;display:none;align-items:center;justify-content:center;}
.modal-overlay.open{display:flex;}
.modal-box{background:rgba(248,250,255,0.98);border:1px solid rgba(255,255,255,0.9);border-radius:18px;box-shadow:0 16px 56px rgba(100,120,180,0.22);overflow:hidden;animation:fadeUp .22s ease both;}
.modal-hd{padding:16px 22px 12px;border-bottom:1px solid rgba(200,210,230,0.4);display:flex;align-items:center;justify-content:space-between;}
.modal-hd-title{font-size:14px;font-weight:700;color:#1e293b;}
.modal-close{width:26px;height:26px;border-radius:50%;border:none;background:rgba(200,210,230,0.4);color:#64748b;cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;transition:all .15s;}
.modal-close:hover{background:#ef4444;color:#fff;}
.modal-body{padding:20px 22px 22px;}
.modal-ft{padding:12px 22px 18px;display:flex;gap:8px;justify-content:flex-end;}
.id-modal .modal-box{width:380px;}
.id-input{width:100%;font-size:14px;padding:10px 14px;border-radius:10px;border:1.5px solid rgba(200,210,230,0.8);background:#fff;color:#1e293b;outline:none;font-family:inherit;transition:border-color .15s;}
.id-input:focus{border-color:#2563eb;}
.mbtn{padding:8px 20px;border-radius:10px;border:none;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;transition:all .15s;}
.mbtn-primary{background:#2563eb;color:#fff;}.mbtn-primary:hover{background:#1d4ed8;}
