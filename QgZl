function ghRaw(file){ return `https://raw.githubusercontent.com/${GH_USER}/${GH_REPO}/main/${GH_FOLDER}/${file}?t=${Date.now()}`; }

// 自动加载云端四个数据文件（公开仓库，无需Token）
async function autoLoadCloudData(){
  showToast('⏳ 正在加载云端数据…');
  const map={ qa:'qa', diff5:'diff5', sum:'sum', diff4:'diff4' };
  let loaded=0;
  for(const [key, fname] of Object.entries(GH_FILES)){
    if(key==='auth') continue;
    try{
      const r=await fetch(ghRaw(fname));
      if(!r.ok) continue;
      const json=await r.json();
      if(json && json.rows){
        DATA[map[key]]=json.rows;
