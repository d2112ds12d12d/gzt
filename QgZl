  const body={message:'Update auth_users.json',content:b64}; if(sha) body.sha=sha;
  const res=await fetch(ghUrl(GH_FILES.auth),{method:'PUT',headers:{Authorization:'token '+_tk(),'Content-Type':'application/json'},body:JSON.stringify(body)});
  if(res.ok) showToast('✓ 授权名单已同步'); else showToast('✗ 同步失败');
}

